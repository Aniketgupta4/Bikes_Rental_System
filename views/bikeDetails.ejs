<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= bike.name %> - Premium Ride | BikeRental</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        /* ----------------------- 1. DESIGN SYSTEM ----------------------- */
        :root {
            --primary: #ff6b6b;
            --primary-dark: #ee5253;
            --secondary: #1e1e2f;
            --bg-body: #f4f7fe;
            --card-bg: #ffffff;
            --text-main: #2d3436;
            --text-muted: #636e72;
            --warning: #f1c40f;
            --success: #00b894;
            --danger: #d63031;
            --shadow: 0 10px 30px rgba(0,0,0,0.08);
            --shadow-sm: 0 5px 15px rgba(0,0,0,0.05);
            --transition: all 0.3s ease;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        html, body { overflow-x: hidden; width: 100%; }
        body { background: var(--bg-body); color: var(--text-main); display: flex; flex-direction: column; min-height: 100vh; }

        /* ----------------------- 2. NAVBAR ----------------------- */
        .navbar {
            background: var(--secondary); padding: 15px 6%;
            display: flex; justify-content: space-between; align-items: center;
            position: sticky; top: 0; z-index: 2000; box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        .navbar .brand { font-size: 1.8rem; font-weight: 700; color: var(--primary); text-decoration: none; letter-spacing: 1px; }
        .navbar .brand span { color: #fff; font-weight: 300; }

        .nav-links { display: flex; gap: 10px; align-items: center; }
        .nav-links a {
            color: #fff; text-decoration: none; padding: 10px 18px; border-radius: 10px;
            font-weight: 500; font-size: 0.9rem; transition: var(--transition);
        }
        .nav-links a:hover { background: rgba(255, 107, 107, 0.1); color: var(--primary); }
        .nav-btn { background: var(--primary); color: #fff !important; }
        .menu-btn { display: none; cursor: pointer; color: #fff; font-size: 1.6rem; }

        /* Mobile Overlay */
        .mobile-overlay {
            position: fixed; top: 0; right: -100%; width: 100%; height: 100%;
            background: var(--secondary); z-index: 2500; transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 25px;
        }
        .mobile-overlay.active { right: 0; }
        .mobile-overlay a { color: #fff; text-decoration: none; font-size: 1.4rem; font-weight: 600; }
        .close-menu { position: absolute; top: 25px; right: 25px; color: #fff; font-size: 2rem; cursor: pointer; }

        /* ----------------------- 3. MODALS & TOASTS ----------------------- */
        .welcome-modal {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8); display: none; align-items: center; justify-content: center;
            z-index: 9999; backdrop-filter: blur(8px);
        }
        .modal-content {
            background: #fff; padding: 40px; border-radius: 35px; text-align: center;
            max-width: 400px; width: 90%; position: relative;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            animation: modalPop 0.6s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        @keyframes modalPop { from { transform: scale(0.6); opacity: 0; } to { transform: scale(1); opacity: 1; } }
        .modal-content i.fa-gift { font-size: 4rem; color: var(--primary); margin-bottom: 15px; display: block; filter: drop-shadow(0 10px 20px rgba(255,107,107,0.3)); }
        .modal-content h3 { font-size: 1.6rem; font-weight: 800; color: var(--secondary); margin-bottom: 10px; }
        .modal-content p { color: var(--text-muted); line-height: 1.6; margin-bottom: 25px; font-size: 0.95rem; }
        .btn-claim {
            background: linear-gradient(45deg, var(--primary), var(--primary-dark));
            color: #fff; border: none; padding: 15px 30px; border-radius: 15px;
            font-weight: 700; cursor: pointer; width: 100%; font-size: 1rem;
            box-shadow: 0 10px 25px rgba(255, 107, 107, 0.3); transition: 0.3s;
        }

        /* PREMIUM TOAST NOTIFICATION */
        #toast-container {
            position: fixed; bottom: -100px; left: 50%; transform: translateX(-50%);
            background: var(--success); color: #fff; padding: 12px 25px; border-radius: 50px;
            display: flex; align-items: center; gap: 10px; font-weight: 600; font-size: 0.95rem;
            box-shadow: 0 10px 30px rgba(0, 184, 148, 0.4); z-index: 3000;
            transition: bottom 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
        }
        #toast-container.show { bottom: 30px; }
        #toast-container.error { background: var(--danger); box-shadow: 0 10px 30px rgba(214, 48, 49, 0.4); }

        /* ----------------------- 4. LAYOUT & VISUALS ----------------------- */
        .container { width: 90%; max-width: 1200px; margin: 30px auto; flex: 1; animation: fadeIn 0.6s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        .bike-details-grid { display: grid; grid-template-columns: 1fr; gap: 30px; }

        .image-card { background: #fff; border-radius: 25px; overflow: hidden; box-shadow: var(--shadow); position: relative; border: 1px solid #edf2f7; }
        .main-img { width: 100%; height: auto; min-height: 250px; max-height: 500px; object-fit: cover; }
        
        .badge-verified { position: absolute; top: 15px; left: 15px; padding: 6px 16px; background: var(--secondary); color: #fff; border-radius: 50px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; box-shadow: 0 4px 10px rgba(0,0,0,0.3); z-index: 10; }

        .specs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(100px, 1fr)); gap: 15px; margin-top: 20px; }
        .spec-item { background: #fff; padding: 15px; border-radius: 15px; text-align: center; border: 1px solid #eee; box-shadow: 0 4px 10px rgba(0,0,0,0.02); transition: var(--transition); }
        .spec-item:hover { transform: translateY(-5px); border-color: var(--primary); }
        .spec-item i { color: var(--primary); font-size: 1.4rem; margin-bottom: 5px; }
        .spec-item p { font-size: 0.75rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; }

        /* ----------------------- 5. BOOKING SIDE ----------------------- */
        .info-card { background: var(--card-bg); padding: 25px; border-radius: 25px; box-shadow: var(--shadow); border: 1px solid #edf2f7; }
        .info-card h2 { font-size: 2rem; color: var(--secondary); font-weight: 800; margin-bottom: 5px; }
        
        .rating-summary-head { display: flex; align-items: center; gap: 8px; margin-bottom: 15px; font-size: 0.95rem; font-weight: 700; color: var(--warning); }
        .rating-summary-head span { color: var(--text-muted); font-weight: 500; }

        .price-row { display: flex; align-items: baseline; gap: 8px; margin-bottom: 20px; }
        .price-row .amt { font-size: 1.8rem; font-weight: 800; color: var(--primary); }
        .price-row .unit { color: var(--text-muted); font-size: 0.9rem; }

        .desc-text { color: var(--text-muted); line-height: 1.7; margin-bottom: 30px; font-size: 0.95rem; }

        .booking-form-box { background: #f8fafc; padding: 20px; border-radius: 20px; border: 1.5px solid #e2e8f0; }
        .welcome-auto-badge { background: #e6fcf5; color: #0ca678; padding: 12px; border-radius: 12px; border: 1px solid #c3fae8; margin-bottom: 20px; font-size: 0.85rem; font-weight: 600; display: none; border-left: 5px solid #0ca678; }

        .input-wrap { margin-bottom: 15px; }
        .input-wrap label { display: block; font-size: 0.8rem; font-weight: 700; color: var(--secondary); margin-bottom: 8px; text-transform: uppercase; }
        .input-wrap input { width: 100%; padding: 12px; border-radius: 10px; border: 2px solid #cbd5e0; font-size: 1rem; outline: none; transition: var(--transition); background: #fff;}
        .input-wrap input:focus { border-color: var(--primary); box-shadow: 0 0 0 4px rgba(255, 107, 107, 0.1); }

        .coupon-box { margin-top: 15px; display: flex; gap: 10px; }
        .coupon-input { flex: 1; padding: 10px 15px; border: 2px dashed #cbd5e0; border-radius: 10px; font-weight: 600; text-transform: uppercase; outline: none; background: #fff; width: 100%; }
        .coupon-input:focus { border-color: var(--primary); }
        .btn-coupon { padding: 10px 20px; background: var(--secondary); color: #fff; border: none; border-radius: 10px; font-weight: 700; cursor: pointer; font-size: 0.85rem; transition: var(--transition); white-space: nowrap;}
        
        .price-summary { background: var(--secondary); color: #fff; padding: 20px; border-radius: 15px; margin-top: 20px; display: none; }
        .summary-line { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.9rem; opacity: 0.8; }
        .total-line { border-top: 1px dashed rgba(255,255,255,0.2); padding-top: 10px; margin-top: 10px; font-weight: 700; color: var(--primary); font-size: 1.1rem; opacity: 1;}

        .btn-submit { width: 100%; padding: 15px; border-radius: 12px; border: none; background: var(--primary); color: #fff; font-size: 1rem; font-weight: 700; cursor: pointer; margin-top: 20px; transition: var(--transition); box-shadow: 0 8px 20px rgba(255, 107, 107, 0.3); }
        .btn-submit:hover { background: var(--primary-dark); transform: translateY(-3px); }

        /* ----------------------- 6. COUPONS SLIDER ----------------------- */
        .coupons-container { margin-bottom: 40px; margin-top: 50px; }
        .coupons-container h3 { margin-bottom: 15px; color: var(--secondary); font-weight: 800; font-size: 1.4rem; }
        .coupon-scroll { display: flex; gap: 15px; overflow-x: auto; padding: 10px 5px; scrollbar-width: none; -ms-overflow-style: none; }
        .coupon-scroll::-webkit-scrollbar { display: none; }
        
        .coupon-card { min-width: 280px; flex: 0 0 auto; background: #fff; padding: 20px; border-radius: 20px; border: 2px dashed var(--primary); position: relative; overflow: hidden; box-shadow: var(--shadow-sm); }
        .coupon-cutout-left { position: absolute; left: -15px; top: 50%; width: 30px; height: 30px; background: var(--bg-body); border-radius: 50%; transform: translateY(-50%); border-right: 2px dashed var(--primary); }
        .coupon-cutout-right { position: absolute; right: -15px; top: 50%; width: 30px; height: 30px; background: var(--bg-body); border-radius: 50%; transform: translateY(-50%); border-left: 2px dashed var(--primary); }
        
        /* ----------------------- 7. REVIEWS ----------------------- */
        .reviews-section { margin-top: 60px; padding-top: 40px; border-top: 2px dashed #e2e8f0; }
        .reviews-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 30px; flex-wrap: wrap; gap: 15px; }
        .reviews-header h3 { font-size: 1.8rem; color: var(--secondary); font-weight: 800; }
        
        .rating-badge { background: #fff9db; color: #f08c00; padding: 10px 20px; border-radius: 15px; font-weight: 800; font-size: 1.4rem; display: flex; align-items: center; gap: 10px; border: 1.5px solid #ffe066; }
        .review-scroll-container { max-height: 450px; overflow-y: auto; padding-right: 10px; }
        .review-scroll-container::-webkit-scrollbar { width: 6px; }
        .review-scroll-container::-webkit-scrollbar-track { background: #f1f5f9; border-radius: 10px; }
        .review-scroll-container::-webkit-scrollbar-thumb { background: #cbd5e0; border-radius: 10px; }
        
        .review-grid { display: flex; flex-direction: column; gap: 20px; }
        .review-card { background: var(--card-bg); padding: 25px; border-radius: 20px; box-shadow: var(--shadow-sm); border: 1px solid #edf2f7; }
        .review-stars { color: var(--warning); margin-bottom: 12px; font-size: 1.1rem; }
        .review-text { color: var(--text-muted); font-size: 0.95rem; font-style: italic; line-height: 1.6; margin-bottom: 20px; }
        
        .review-author { display: flex; align-items: center; gap: 15px; border-top: 1px solid #f1f5f9; padding-top: 15px; }
        .user-avatar { width: 45px; height: 45px; border-radius: 50%; background: var(--secondary); color: #fff; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; font-weight: 700; flex-shrink: 0; }
        .user-details { display: flex; flex-direction: column; }
        .user-name { font-weight: 800; color: var(--secondary); font-size: 0.95rem; display: flex; align-items: center; gap: 6px; }
        .user-time { color: #94a3b8; font-size: 0.8rem; font-weight: 500; margin-top: 2px; }

        /* ----------------------- 8. NEW ENTERPRISE FOOTER ----------------------- */
        footer {
            background: var(--secondary);
            color: #fff;
            padding: 70px 6% 30px;
            margin-top: 80px;
            border-top: 5px solid var(--primary);
        }
        .footer-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 40px;
            max-width: 1200px;
            margin: 0 auto;
        }
        .footer-col h3 { color: var(--primary); font-size: 1.8rem; font-weight: 800; margin-bottom: 20px; }
        .footer-col h4 { color: #fff; font-size: 1.2rem; font-weight: 700; margin-bottom: 25px; position: relative; padding-bottom: 10px; }
        .footer-col h4::after { content: ''; position: absolute; left: 0; bottom: 0; width: 35px; height: 3px; background: var(--primary); border-radius: 10px; }
        .footer-col p { color: #cbd5e0; line-height: 1.7; font-size: 0.95rem; margin-bottom: 20px; }

        /* Social Icons */
        .social-links { display: flex; gap: 15px; margin-top: 20px; }
        .social-links a {
            color: #fff;
            background: rgba(255, 255, 255, 0.1);
            width: 40px; height: 40px;
            display: flex; align-items: center; justify-content: center;
            border-radius: 8px; font-size: 1.1rem; transition: var(--transition);
        }
        .social-links a:hover { background: var(--primary); transform: translateY(-3px); }

        /* Links List */
        .footer-links { list-style: none; }
        .footer-links li { margin-bottom: 15px; }
        .footer-links a { color: #cbd5e0; text-decoration: none; transition: var(--transition); font-size: 0.95rem; }
        .footer-links a:hover { color: var(--primary); padding-left: 5px; }

        /* Contact Items */
        .contact-item { display: flex; align-items: center; gap: 12px; margin-bottom: 18px; color: #cbd5e0; font-size: 0.95rem; }
        .contact-item i { color: var(--primary); font-size: 1.1rem; }

        /* Feedback Form In Footer */
        .feedback-form input, .feedback-form textarea {
            width: 100%; padding: 12px; background: #2d2d44; border: 1px solid #3d3d5c;
            border-radius: 8px; color: #fff; margin-bottom: 12px; outline: none; font-family: inherit;
        }
        .btn-submit-note {
            width: 100%; padding: 12px; background: var(--primary); color: #fff;
            border: none; border-radius: 8px; font-weight: 700; cursor: pointer; transition: var(--transition);
        }
        .btn-submit-note:hover { background: var(--primary-dark); }

        /* Copyright Bar */
        .copyright-bar { text-align: center; padding-top: 30px; margin-top: 60px; border-top: 1px solid #2d2d44; color: #636e72; font-size: 0.85rem; }

        /* ----------------------- 9. RESPONSIVENESS (MOBILE/TABLET) ----------------------- */
        @media (min-width: 992px) {
            .bike-details-grid { grid-template-columns: 1.2fr 0.8fr; }
            .visual-side { position: sticky; top: 100px; height: fit-content; }
            .info-card { padding: 40px; }
            .info-card h2 { font-size: 2.5rem; }
        }
        
        @media (max-width: 768px) {
            .navbar { padding: 15px 5%; }
            .nav-links { display: none; }
            .menu-btn { display: block; }
            
            /* Make layout stack properly on mobile */
            .container { width: 95%; margin: 20px auto; }
            .bike-details-grid { gap: 20px; }
            
            .image-card { border-radius: 15px; }
            .main-img { min-height: 200px; }
            .specs-grid { grid-template-columns: repeat(3, 1fr); gap: 10px; }
            
            .info-card { padding: 20px; border-radius: 15px; }
            .info-card h2 { font-size: 1.6rem; }
            .price-row .amt { font-size: 1.5rem; }
            
            /* Form adaptations */
            .booking-form-box { padding: 15px; }
            .coupon-box { flex-direction: column; }
            .btn-coupon { width: 100%; padding: 12px; }
            
            .reviews-header { flex-direction: column; align-items: flex-start; }
            .rating-badge { width: 100%; justify-content: center; }
            
            /* Enterprise Footer adaptations */
            footer { padding: 50px 5% 30px; text-align: center; }
            .footer-col h4::after { left: 50%; transform: translateX(-50%); }
            .social-links { justify-content: center; }
            .contact-item { justify-content: center; }
        }
        @media (max-width: 480px) {
            .specs-grid { grid-template-columns: 1fr; }
        }
    </style>
</head>
<body>

    <div id="welcomeModal" class="welcome-modal">
        <div class="modal-content">
            <i class="fas fa-gift"></i>
            <h3>Surprise Gift! 🎁</h3>
           <p>Welcome to BikeRental! Since this is your first ride with us, enjoy a flat <b>₹100 OFF</b>. This discount will be automatically applied to your total bill at checkout!</p>
           <button class="btn-claim" onclick="closeModal()">Awesome!</button>
        </div>
    </div>

    <div id="toast-container">
        <i id="toastIcon" class="fas fa-check-circle"></i>
        <span id="toastMsg">Notification</span>
    </div>

    <header class="navbar">
        <a href="/" class="brand">Bike<span>Rental</span></a>
        <div class="menu-btn" onclick="toggleMenu()"><i class="fas fa-bars"></i></div>
        <nav class="nav-links">
            <a href="/">Home</a>
            <% if (user) { %>
                <a href="/user/dashboard">Dashboard</a>
                <a href="/logout" class="nav-btn">Logout</a>
            <% } else { %>
                <a href="/login">Login</a>
                <a href="/signup" class="nav-btn">Signup</a>
            <% } %>
        </nav>
    </header>

    <div class="mobile-overlay" id="mobileNav">
        <div class="close-menu" onclick="toggleMenu()"><i class="fas fa-times"></i></div>
        <a href="/" onclick="toggleMenu()">Home</a>
        <% if (user) { %>
            <a href="/user/dashboard" onclick="toggleMenu()">Dashboard</a>
            <a href="/logout" onclick="toggleMenu()">Logout</a>
        <% } else { %>
            <a href="/login" onclick="toggleMenu()">Login</a>
            <a href="/signup" onclick="toggleMenu()">Signup</a>
        <% } %>
    </div>

    <main class="container">
        <div class="bike-details-grid">
            
            <div class="visual-side">
                <div class="image-card">
                    <span class="badge-verified"><i class="fas fa-shield-check"></i> Verified Ride</span>
                    <% if (bike.image) { %>
                        <img src="<%= bike.image %>" class="main-img" alt="<%= bike.name %>">
                    <% } else { %>
                        <img src="https://via.placeholder.com/800x500?text=Bike+Image" class="main-img" alt="Placeholder">
                    <% } %>
                </div>

                <div class="specs-grid">
                    <div class="spec-item"><i class="fas fa-bolt"></i><p>High Performance</p></div>
                    <div class="spec-item"><i class="fas fa-gas-pump"></i><p>Fuel Efficient</p></div>
                    <div class="spec-item"><i class="fas fa-helmet-safety"></i><p>Safety Insured</p></div>
                </div>
            </div>

            <div class="info-side">
                <div class="info-card">
                    <h2><%= bike.name %></h2>
                    
                    <% if (bike.reviews && bike.reviews.length > 0) { %>
                        <div class="rating-summary-head">
                            <i class="fas fa-star"></i> <%= bike.averageRating || '0.0' %> 
                            <span>(<%= bike.reviews.length %> Reviews)</span>
                        </div>
                    <% } else { %>
                        <div class="rating-summary-head">
                            <i class="far fa-star"></i> New Listing
                        </div>
                    <% } %>

                    <div class="price-row">
                        <span class="amt">₹ <%= bike.pricePerDay %></span>
                        <span class="unit">/ full day</span>
                    </div>
                    <p class="desc-text"><%= bike.description %></p>

                    <% if (user && user.role === 'user') { %>
                        <div class="booking-form-box">
                            <form action="/user/book/<%= bike._id %>" method="POST" id="bookingForm">
                                
                                <div id="welcomeOfferIndicator" class="welcome-auto-badge">
                                    <i class="fas fa-sparkles"></i> <b>Welcome Offer Applied!</b> ₹100 Deducted from your first ride.
                                </div>

                                <div class="input-wrap">
                                    <label><i class="far fa-calendar-alt"></i> Pick-up Date & Time</label>
                                    <input type="datetime-local" name="pickupDateTime" id="pickupDate" required>
                                </div>

                                <div class="input-wrap">
                                    <label><i class="far fa-calendar-check"></i> Return Date & Time</label>
                                    <input type="datetime-local" name="returnDateTime" id="returnDate" required>
                                </div>

                                <div id="couponSection" style="display: none;">
                                    <label style="font-size: 0.8rem; font-weight: 700; color: var(--secondary); text-transform: uppercase;">Apply Manual Coupon</label>
                                    <div class="coupon-box">
                                        <input type="text" id="couponCode" class="coupon-input" placeholder="e.g. WELCOME50">
                                        <button type="button" id="btnApplyCoupon" class="btn-coupon">Apply</button>
                                    </div>
                                </div>

                                <div class="price-summary" id="priceSummary">
                                    <div class="summary-line">
                                        <span>Duration:</span>
                                        <span id="displayDays">0 Days</span>
                                    </div>
                                    <div class="summary-line" id="welcomeDiscountLine" style="display: none; color: #0ca678; font-weight: 700;">
                                        <span>Welcome Discount:</span><span>- ₹ 100</span>
                                    </div>
                                    <div class="summary-line" id="discountLine" style="display: none; color: var(--success); font-weight: 700;">
                                        <span>Coupon Savings:</span>
                                        <span id="displayDiscount">- ₹ 0</span>
                                    </div>
                                    <div class="summary-line total-line">
                                        <span>Amount to Pay:</span>
                                        <span id="displayTotal">₹ 0</span>
                                    </div>
                                </div>

                                <input type="hidden" name="appliedCoupon" id="hiddenCouponCode">
                                <button class="btn-submit" type="submit">Reserve This Ride</button>
                            </form>
                        </div>
                    <% } else { %>
                        <div style="background: #fff5f5; padding: 25px; border-radius: 20px; border: 1px solid #feb2b2; text-align: center;">
                            <p style="color: #c53030; font-weight: 700; margin-bottom: 10px;">Ready to ride?</p>
                            <a href="/login" style="color: var(--primary); font-weight: 800; text-decoration: underline;">Login to complete booking</a>
                        </div>
                    <% } %>
                </div>
            </div>
        </div>

        <% if (typeof coupons !== 'undefined' && coupons.length > 0) { %>
        <section class="coupons-container">
            <h3><i class="fas fa-fire" style="color: #e67e22;"></i> Exclusive Offers for You</h3>
            <div class="coupon-scroll">
                <% coupons.forEach(coupon => { %>
                    <div class="coupon-card">
                        <div class="coupon-cutout-left"></div>
                        <div class="coupon-cutout-right"></div>
                        <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 8px;">
                            <i class="fas fa-ticket-alt" style="color: var(--primary); font-size: 1.2rem;"></i>
                            <span style="font-weight: 800; font-size: 1.1rem; color: var(--secondary);">
                                <%= coupon.discountType === 'percentage' ? coupon.discountValue + '%' : '₹' + coupon.discountValue %> OFF
                            </span>
                        </div>
                        <p style="font-size: 0.8rem; color: var(--text-muted); margin-bottom: 15px;">
                            <%= coupon.isFirstTimeOnly ? 'Valid on your first ride only' : 'Valid on all rentals' %>
                        </p>
                        <div style="display: flex; justify-content: space-between; align-items: center;">
                            <div style="background: #f4f7fe; padding: 5px 12px; border-radius: 8px; font-family: monospace; font-weight: 800; color: var(--primary); border: 1px solid #e2e8f0; letter-spacing: 1px;">
                                <%= coupon.code %>
                            </div>
                            <button type="button" onclick="copyCode('<%= coupon.code %>')" style="background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 1rem;" title="Copy Code">
                                <i class="far fa-copy"></i>
                            </button>
                        </div>
                    </div>
                <% }) %>
            </div>
        </section>
        <% } %>



         
<script src="/js/paymentHandler.js"></script>

        <div class="reviews-section">
            <div class="reviews-header">
                <div>
                    <h3>Rider Reviews</h3>
                    <p style="color: var(--text-muted); font-size: 0.95rem;">See what others are saying about this bike.</p>
                </div>
                <div class="rating-badge">
                    <i class="fas fa-star"></i> 
                    <%= bike.averageRating ? bike.averageRating : '0.0' %> 
                    <span style="font-size: 1rem; color: var(--text-muted); font-weight: 600;">
                        (<%= bike.reviews ? bike.reviews.length : 0 %>)
                    </span>
                </div>
            </div>

            <% if (bike.reviews && bike.reviews.length > 0) { %>
                <div class="review-scroll-container">
                    <div class="review-grid">
                        <% bike.reviews.reverse().forEach(review => { %> 
                            <div class="review-card">
                                <div class="review-stars">
                                    <% for(let i=1; i<=5; i++) { %>
                                        <i class="<%= i <= review.rating ? 'fas' : 'far' %> fa-star"></i>
                                    <% } %>
                                </div>
                                <p class="review-text">"<%= review.comment %>"</p>
                                <div class="review-author">
                                    <div class="user-avatar"><%= review.user && review.user.name ? review.user.name.charAt(0).toUpperCase() : 'V' %></div>
                                    <div class="user-details">
                                        <span class="user-name"><%= review.user ? review.user.name : 'Verified Rider' %> <i class="fas fa-check-circle" style="color: var(--success); font-size: 0.85rem;"></i></span>
                                        <span class="user-time"><%= new Date(review.createdAt).toLocaleString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %></span>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                </div>
            <% } else { %>
                <div style="text-align: center; padding: 50px 20px; background: #fff; border-radius: 20px; border: 2px dashed #edf2f7;">
                    <i class="fas fa-comment-slash fa-3x" style="color: #cbd5e0; margin-bottom: 15px;"></i>
                    <h4 style="color: var(--secondary); font-weight: 700;">No Reviews Yet</h4>
                    <p style="color: var(--text-muted);">Be the first one to ride and rate this bike!</p>
                </div>
            <% } %>
        </div>
    </main>


    <footer>
        <div class="footer-grid">
            <div class="footer-col">
                <h3>BikeRental</h3>
                <p>Providing premium urban mobility solutions since 2026. Safe, reliable, and performance-driven bikes for every journey.</p>
                <div class="social-links">
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-x-twitter"></i></a>
                </div>
            </div>

            <div class="footer-col">
                <h4>Navigation</h4>
                <ul class="footer-links">
                    <li><a href="/">Browse Fleet</a></li>
                    <li><a href="/user/dashboard">Ride History</a></li>
                    <li><a href="#">Join Community</a></li>
                    <li><a href="#">Security Policy</a></li>
                </ul>
            </div>

            <div class="footer-col">
                <h4>Support Hub</h4>
                <div class="contact-item">
                    <i class="fas fa-envelope"></i>
                    <span>support@bikerental.com</span>
                </div>
                <div class="contact-item">
                    <i class="fas fa-map-marker-alt"></i>
                    <span>Civil Lines, Jabalpur, MP</span>
                </div>
            </div>

            <div class="footer-col">
                <h4>Direct Feedback</h4>
                <form class="feedback-form" action="/feedback" method="POST">
                    <input type="text" name="name" placeholder="Your Name" required>
                    <textarea name="message" rows="2" placeholder="Your message..." required></textarea>
                    <button type="submit" class="btn-submit-note">Send Message</button>
                </form>
            </div>
        </div>

        <div class="copyright-bar">
            <p>© <%= new Date().getFullYear() %> BikeRental System | Built with ❤️ by Aniket Kumar Gupta | SRIT Jabalpur</p>
        </div>
    </footer>
    <script>
        // Menu & Modals
        function toggleMenu() { document.getElementById("mobileNav").classList.toggle("active"); }
        function closeModal() { document.getElementById("welcomeModal").style.display = "none"; }
        
        // Advanced Toast Notification (Replaces Browser Alert)
        function showToast(message, isError = false) {
            const toast = document.getElementById("toast-container");
            const icon = document.getElementById("toastIcon");
            
            document.getElementById("toastMsg").innerText = message;
            
            if(isError) {
                toast.classList.add("error");
                icon.className = "fas fa-times-circle";
            } else {
                toast.classList.remove("error");
                icon.className = "fas fa-check-circle";
            }
            
            toast.classList.add("show");
            setTimeout(() => { toast.classList.remove("show"); }, 3000);
        }

        // Copy Code to Clipboard & Auto-fill
        function copyCode(code) {
            navigator.clipboard.writeText(code).then(() => {
                showToast(`Code ${code} copied! Use it above.`);
                const input = document.getElementById('couponCode');
                if(input) { input.value = code; input.focus(); }
            }).catch(() => {
                showToast("Failed to copy code.", true);
            });
        }

        document.addEventListener('DOMContentLoaded', () => {
            const pickupInput = document.getElementById('pickupDate');
            const returnInput = document.getElementById('returnDate');
            const priceSummary = document.getElementById('priceSummary');
            const couponSection = document.getElementById('couponSection');
            
            const displayTotal = document.getElementById('displayTotal');
            const discountLine = document.getElementById('discountLine');
            const welcomeDiscountLine = document.getElementById('welcomeDiscountLine');
            const welcomeAutoBadge = document.getElementById('welcomeOfferIndicator');
            const displayDiscount = document.getElementById('displayDiscount');
            
            const btnApply = document.getElementById('btnApplyCoupon');
            const couponInput = document.getElementById('couponCode');

            const pricePerDay = Number('<%= bike.pricePerDay %>') || 0;
            const isFirstTimeUser = <%= (user && user.isFirstTimeUser) ? 'true' : 'false' %>;

            // Welcome Modal Trigger
            if(isFirstTimeUser) {
                setTimeout(() => { document.getElementById('welcomeModal').style.display = 'flex'; }, 800); 
            }

            let currentBaseTotal = 0;
            let currentManualDiscount = 0;

            if(pickupInput && returnInput) {
                const now = new Date();
                now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
                pickupInput.min = now.toISOString().slice(0, 16);

                function calculatePrice() {
                    const start = new Date(pickupInput.value);
                    const end = new Date(returnInput.value);

                    if (pickupInput.value && returnInput.value && end > start) {
                        const diffInMs = Math.abs(end - start);
                        const diffInDays = Math.ceil(diffInMs / (1000 * 60 * 60 * 24)); 
                        currentBaseTotal = diffInDays * pricePerDay;

                        document.getElementById('displayDays').innerText = `${diffInDays} Day(s)`;
                        updateFinalDisplay();
                        
                        priceSummary.style.display = 'block';
                        couponSection.style.display = 'block';

                        if(isFirstTimeUser && welcomeAutoBadge && welcomeDiscountLine) {
                            welcomeAutoBadge.style.display = 'block';
                            welcomeDiscountLine.style.display = 'flex';
                        }
                    } else {
                        priceSummary.style.display = 'none';
                        couponSection.style.display = 'none';
                    }
                }

                function updateFinalDisplay() {
                    let autoDiscount = isFirstTimeUser ? 100 : 0;
                    let totalDeduction = autoDiscount + currentManualDiscount;
                    const final = Math.max(0, currentBaseTotal - totalDeduction);
                    
                    if(currentManualDiscount > 0) {
                        discountLine.style.display = 'flex';
                        displayDiscount.innerText = `- ₹ ${currentManualDiscount}`;
                    } else {
                        discountLine.style.display = 'none';
                    }
                    displayTotal.innerText = `₹ ${final}`;
                }

                pickupInput.addEventListener('change', () => { returnInput.min = pickupInput.value; calculatePrice(); });
                returnInput.addEventListener('change', calculatePrice);

                btnApply.addEventListener('click', async () => {
                    const code = couponInput.value.trim();
                    if(!code) return showToast("Please enter a code", true);
                    
                    btnApply.innerText = "...";
                    try {
                        const response = await fetch('/api/validate-coupon', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ code: code, totalAmount: currentBaseTotal })
                        });
                        const data = await response.json();
                        
                        if(data.success) {
                            currentManualDiscount = data.discount;
                            showToast(data.message);
                            document.getElementById('hiddenCouponCode').value = code;
                            updateFinalDisplay();
                        } else {
                            currentManualDiscount = 0;
                            showToast(data.message, true);
                            updateFinalDisplay();
                        }
                    } catch (err) { 
                        showToast("Server Error!", true); 
                    } finally { 
                        btnApply.innerText = "Apply"; 
                    }
                });
            }
        });
    </script>




</body>
</html>