<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Coupon Center - Admin Control</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        /* ----------------------- 1. DESIGN SYSTEM ----------------------- */
        :root {
            --primary: #ff6b6b;
            --primary-dark: #ee5253;
            --secondary: #1e1e2f;
            --bg-body: #f4f7fe;
            --card-bg: #ffffff;
            --text-main: #2d3436;
            --text-muted: #636e72;
            --success: #00b894;
            --warning: #f1c40f; 
            --danger: #d63031;
            --shadow: 0 10px 30px rgba(0,0,0,0.05);
            --shadow-sm: 0 5px 15px rgba(0,0,0,0.05);
            --transition: all 0.3s ease;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        body { background: var(--bg-body); color: var(--text-main); display: flex; flex-direction: column; min-height: 100vh; overflow-x: hidden; }

        /* ----------------------- 2. NAVBAR ----------------------- */
        .navbar {
            background: var(--secondary); padding: 15px 6%;
            display: flex; justify-content: space-between; align-items: center;
            position: sticky; top: 0; z-index: 2000; box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        .navbar .brand { font-size: 1.6rem; font-weight: 800; color: var(--primary); text-decoration: none; letter-spacing: 1px; }
        .navbar .brand span { color: #fff; font-weight: 300; }
        .nav-link { color: #fff; text-decoration: none; font-weight: 500; font-size: 0.9rem; transition: var(--transition); display: flex; align-items: center; gap: 8px; }
        .nav-link:hover { color: var(--primary); }

        /* ----------------------- 3. MAIN CONTENT ----------------------- */
        .container { width: 92%; max-width: 1200px; margin: 40px auto; flex: 1; }

        .page-header { margin-bottom: 30px; }
        .page-header h2 { font-size: 1.8rem; font-weight: 800; color: var(--secondary); margin-bottom: 5px; }
        .page-header p { color: var(--text-muted); font-size: 0.95rem; }

        /* --- FORM CARD --- */
        .card {
            background: var(--card-bg); border-radius: 20px; padding: 30px;
            box-shadow: var(--shadow); border: 1px solid #edf2f7; margin-bottom: 40px;
        }
        .card h3 { font-size: 1.2rem; font-weight: 700; margin-bottom: 25px; color: var(--secondary); display: flex; align-items: center; gap: 10px; }
        .card h3 i { color: var(--primary); }

        .form-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; }
        .form-group { display: flex; flex-direction: column; gap: 8px; }
        .form-group label { font-size: 0.75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
        
        .form-control {
            width: 100%; padding: 12px 15px; border-radius: 12px; border: 2px solid #e2e8f0;
            font-size: 0.95rem; font-family: inherit; outline: none; transition: var(--transition); background: #f8fafc;
        }
        .form-control:focus { border-color: var(--primary); background: #fff; box-shadow: 0 0 0 4px rgba(255, 107, 107, 0.1); }

        .checkbox-group { display: flex; align-items: center; gap: 10px; margin-top: 15px; cursor: pointer; width: fit-content; }
        .checkbox-group input { width: 18px; height: 18px; accent-color: var(--primary); }
        .checkbox-group span { font-size: 0.9rem; font-weight: 600; color: var(--secondary); }

        .btn-save {
            background: var(--primary); color: #fff; border: none; padding: 14px 30px; border-radius: 12px;
            font-weight: 700; cursor: pointer; transition: var(--transition); margin-top: 25px; width: 100%; max-width: 200px;
            box-shadow: 0 8px 20px rgba(255, 107, 107, 0.2);
        }
        .btn-save:hover { background: var(--primary-dark); transform: translateY(-2px); }

        /* --- TABLE SECTION --- */
        .data-card { background: #fff; border-radius: 20px; overflow: hidden; box-shadow: var(--shadow); border: 1px solid #edf2f7; }
        table { width: 100%; border-collapse: collapse; }
        table th { background: #f8fafc; padding: 18px 20px; text-align: left; font-size: 0.75rem; text-transform: uppercase; color: var(--text-muted); font-weight: 700; }
        table td { padding: 18px 20px; border-top: 1px solid #f1f5f9; font-size: 0.95rem; vertical-align: middle; }
        table tr:hover { background: #fcfdfe; }

        .coupon-tag { background: #f1f5f9; padding: 6px 12px; border-radius: 8px; font-weight: 700; color: var(--secondary); border: 1px solid #e2e8f0; font-size: 0.85rem; letter-spacing: 0.5px;}
        .discount-val { color: var(--success); font-weight: 800; font-size: 1.1rem; }
        
        .badge { padding: 6px 14px; border-radius: 30px; font-size: 0.75rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px;}
        .badge-new { background: #e6fcf5; color: #0ca678; }
        .badge-all { background: #e3f2fd; color: #1976d2; }

        .btn-delete { color: var(--danger); background: #fff5f5; border: none; width: 38px; height: 38px; border-radius: 10px; cursor: pointer; transition: var(--transition); display: flex; align-items: center; justify-content: center;}
        .btn-delete:hover { background: var(--danger); color: #fff; transform: scale(1.1); }



        /* Social Icons */
        .social-links { display: flex; gap: 15px; margin-top: 20px; }
        .social-links a {
            color: #fff; background: rgba(255, 255, 255, 0.1);
            width: 40px; height: 40px; display: flex; align-items: center; justify-content: center;
            border-radius: 8px; font-size: 1.1rem; transition: var(--transition);
        }
        .social-links a:hover { background: var(--primary); transform: translateY(-3px); }

        /* Links List */
        .footer-links { list-style: none; }
        .footer-links li { margin-bottom: 15px; }
        .footer-links a { color: #cbd5e0; text-decoration: none; transition: var(--transition); font-size: 0.95rem; display: inline-block;}
        .footer-links a:hover { color: var(--primary); transform: translateX(5px); }

        /* Contact Items */
        .contact-item { display: flex; align-items: center; gap: 15px; margin-bottom: 18px; color: #cbd5e0; font-size: 0.95rem; }
        .contact-item i { color: var(--primary); font-size: 1.1rem; width: 20px; text-align: center;}

        /* Feedback Form In Footer */
        .feedback-form input, .feedback-form textarea {
            width: 100%; padding: 12px 15px; background: #2d2d44; border: 1px solid #3d3d5c;
            border-radius: 8px; color: #fff; margin-bottom: 12px; outline: none; font-family: inherit; font-size: 0.95rem;
        }
        .feedback-form input:focus, .feedback-form textarea:focus { border-color: var(--primary); }
        .btn-submit-note {
            width: 100%; padding: 14px; background: var(--primary); color: #fff;
            border: none; border-radius: 8px; font-weight: 700; cursor: pointer; transition: var(--transition); font-size: 1rem;
        }
        .btn-submit-note:hover { background: var(--primary-dark); }

        /* Copyright Bar */
        .copyright-bar {
            text-align: center; padding-top: 30px; margin-top: 60px; border-top: 1px solid #2d2d44;
            color: #636e72; font-size: 0.85rem; line-height: 1.6;
        }

        /* ----------------------- 5. FULL RESPONSIVENESS (MOBILE/TABLET) ----------------------- */
        @media (max-width: 992px) {
            .footer-grid { grid-template-columns: repeat(2, 1fr); }
        }

        @media (max-width: 768px) {
            .navbar { padding: 15px 5%; }
            .container { width: 95%; margin: 20px auto; }
            .card { padding: 20px; }
            .page-header h2 { font-size: 1.5rem; }
            .btn-save { max-width: 100%; }

            /* Advanced Mobile Table (Card Layout) */
            .data-card { background: transparent; box-shadow: none; border: none; }
            table thead { display: none; }
            table, tbody, tr, td { display: block; width: 100%; }
            table tr { background: #fff; margin-bottom: 15px; border-radius: 15px; box-shadow: var(--shadow-sm); padding: 15px; border: 1px solid #edf2f7; }
            
            table td { 
                display: flex; justify-content: space-between; align-items: center; 
                padding: 12px 5px; border-bottom: 1px dashed #e2e8f0; text-align: right; 
            }
            table td::before { 
                content: attr(data-label); font-weight: 700; text-transform: uppercase; 
                font-size: 0.75rem; color: var(--text-muted); text-align: left; 
            }
            table td:last-child { border-bottom: none; padding-bottom: 5px; }

            /* Mobile Footer Adjustments */
            .footer-grid { grid-template-columns: 1fr; gap: 40px; text-align: center; }
            .footer-col h4::after { left: 50%; transform: translateX(-50%); }
            .social-links { justify-content: center; }
            .contact-item { justify-content: center; }
            .footer-links a:hover { transform: translateY(-3px) translateX(0); } /* Adjust hover animation for center alignment */
        }

        @media (max-width: 480px) {
            .navbar .brand { font-size: 1.4rem; }
            .nav-link span { display: none; } /* Hide "Back to Dashboard" text on very small screens, show only icon */
            .nav-link i { font-size: 1.2rem; }
        }
    </style>
</head>
<body>

    <header class="navbar">
        <a href="/" class="brand">Bike<span> Rental</span></a>
        <nav>
            <a href="/admin/dashboard" class="nav-link">
                <i class="fas fa-arrow-left"></i> <span>Dashboard</span>
            </a>
        </nav>
    </header>

    <main class="container">
        <div class="page-header">
            <h2>Offers & Coupons</h2>
            <p>Create and manage festive discounts or welcome offers for your riders.</p>
        </div>

        <div class="card">
            <h3><i class="fas fa-magic"></i> Create New Coupon</h3>
            <form action="/admin/add-coupon" method="POST">
                <div class="form-grid">
                    <div class="form-group">
                        <label>Coupon Code</label>
                        <input type="text" name="code" class="form-control" placeholder="e.g. SUMMER2026" required>
                    </div>
                    <div class="form-group">
                        <label>Discount Type</label>
                        <select name="discountType" class="form-control">
                            <option value="fixed">Fixed Amount (₹)</option>
                            <option value="percentage">Percentage (%)</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label>Discount Value</label>
                        <input type="number" name="discountValue" class="form-control" placeholder="100" required>
                    </div>
                    <div class="form-group">
                        <label>Expiry Date</label>
                        <input type="date" name="expiryDate" class="form-control" required>
                    </div>
                </div>

                <label class="checkbox-group" for="ft">
                    <input type="checkbox" name="isFirstTimeOnly" id="ft" value="true"> 
                    <span>Only for New User's First Ride</span>
                </label>

                <button type="submit" class="btn-save">Create Offer</button>
            </form>
        </div>

        <div class="data-card">
            <table>
                <thead>
                    <tr>
                        <th>Coupon Code</th>
                        <th>Discount Value</th>
                        <th>Valid Until</th>
                        <th>Applicable To</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    <% if(typeof coupons !== 'undefined' && coupons.length > 0) { %>
                        <% coupons.forEach(c => { %>
                            <tr id="row-<%= c._id %>">
                                <td data-label="Coupon Code"><span class="coupon-tag"># <%= c.code %></span></td>
                                <td data-label="Discount Value" class="discount-val">
                                    <%= c.discountType === 'fixed' ? '₹' : '' %><%= c.discountValue %><%= c.discountType === 'percentage' ? '%' : '' %>
                                </td>
                                <td data-label="Valid Until" style="color: var(--text-muted); font-weight: 500;">
                                    <%= new Date(c.expiryDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
                                </td>
                                <td data-label="Applicable To">
                                    <span class="badge <%= c.isFirstTimeOnly ? 'badge-new' : 'badge-all' %>">
                                        <%= c.isFirstTimeOnly ? 'New Riders' : 'All Riders' %>
                                    </span>
                                </td>
                                <td data-label="Action">
                                    <button onclick="deleteCoupon('<%= c._id %>')" class="btn-delete" title="Remove Coupon">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </td>
                            </tr>
                        <% }) %>
                    <% } else { %>
                        <tr>
                            <td colspan="5" style="text-align: center; padding: 60px 20px; color: var(--text-muted); border-radius: 15px;">
                                <i class="fas fa-ticket-alt fa-3x" style="margin-bottom: 15px; opacity: 0.2;"></i>
                                <p>No active coupons found. Create one above!</p>
                            </td>
                        </tr>
                    <% } %>
                </tbody>
            </table>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script>
        async function deleteCoupon(id) {
            if(!confirm('Are you sure you want to delete this coupon permanently?')) return;
            try {
                const res = await fetch(`/admin/delete-coupon/${id}`, { method: 'DELETE' });
                if(res.ok) {
                    const row = document.getElementById(`row-${id}`);
                    row.style.opacity = '0';
                    row.style.transform = 'translateX(20px)';
                    setTimeout(() => row.remove(), 300);
                } else {
                    alert("Failed to delete coupon.");
                }
            } catch (err) {
                console.error(err);
                alert("Server error.");
            }
        }
        
        // Prevent creating past coupons
        document.querySelector('input[type="date"]').min = new Date().toISOString().split("T")[0];
    </script>
</body>
</html>