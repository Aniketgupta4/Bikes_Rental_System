  <script>
    // 1. SMART SCROLL MEMORY LOGIC 
    document.querySelectorAll('.save-scroll').forEach(link => {
        link.addEventListener('click', () => {
            localStorage.setItem('adminScrollPosition', window.scrollY);
        });
    });

    function saveScrollPos() {
        localStorage.setItem('adminScrollPosition', window.scrollY);
    }

    window.addEventListener('load', () => {
        const savedScrollPos = localStorage.getItem('adminScrollPosition');
        if (savedScrollPos) {
            window.scrollTo({ top: parseInt(savedScrollPos), behavior: 'auto' });
            localStorage.removeItem('adminScrollPosition');
        }

        document.querySelectorAll('.data-card').forEach((card, index) => {
            card.style.opacity = '0';
            card.style.transform = 'translateY(20px)';
            card.style.transition = `all 0.6s ease ${index * 0.2}s`;
            setTimeout(() => {
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
            }, 50);
        });
    });

    // 2. MOBILE NAVBAR LOGIC
    const menuToggle = document.getElementById('menuToggle');
    const navMenu = document.getElementById('navMenu');

    menuToggle.addEventListener('click', () => {
      navMenu.classList.toggle('active');
      const icon = menuToggle.querySelector('i');
      if (navMenu.classList.contains('active')) {
          icon.classList.replace('fa-bars', 'fa-times');
      } else {
          icon.classList.replace('fa-times', 'fa-bars');
      }
    });
  </script>

