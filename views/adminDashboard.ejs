<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0"> 
  <title>Admin Control Center - BikeRental</title>
  
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  
  <style>
    /* ---------------------------------------------------- */
    /* 1. CORE VARIABLES & DESIGN SYSTEM */
    /* ---------------------------------------------------- */
    :root {
      --primary: #ff6b6b;
      --primary-dark: #ee5253;
      --secondary: #1e1e2f;
      --bg-body: #f4f7fe;
      --card-bg: #ffffff;
      --text-main: #2d3436;
      --text-muted: #636e72;
      --success: #00b894;
      --warning: #f1c40f;
      --info: #0984e3;
      --danger: #d63031;
      --shadow: 0 10px 30px rgba(0,0,0,0.05);
    }

    * { margin:0; padding:0; box-sizing:border-box; font-family:'Poppins', sans-serif; }
    html, body { height:100%; scroll-behavior: smooth; } 
    body { background: var(--bg-body); color: var(--text-main); display:flex; flex-direction:column; overflow-x: hidden; width: 100vw; max-width: 100%; }

    /* ---------------------------------------------------- */
    /* 2. PREMIUM HEADER */
    /* ---------------------------------------------------- */
    header {
      background: var(--secondary); color: #fff; padding: 12px 6%;
      display: flex; justify-content: space-between; align-items: center;
      position: sticky; top: 0; z-index: 1000; box-shadow: 0 4px 15px rgba(0,0,0,0.2);
    }
    header h1 { font-size: 1.8rem; font-weight: 700; color: var(--primary); letter-spacing: 1px; }
    header h1 span { color: #fff; font-weight: 300; }

    nav { display: flex; gap: 10px; align-items: center; transition: 0.3s ease; }
    nav a {
      color: #fff; text-decoration: none; padding: 10px 18px;
      border-radius: 8px; transition: 0.3s ease; font-weight: 500; font-size: 0.9rem;
    }
    nav a:hover { background: rgba(255, 107, 107, 0.1); color: var(--primary); }
    .nav-active { background: rgba(255, 107, 107, 0.15); color: var(--primary); }
    .logout-btn { background: var(--primary); color: #fff; }
    .logout-btn:hover { background: var(--primary-dark); transform: scale(1.05); }

    .menu-toggle { display: none; background: none; border: none; color: #fff; font-size: 1.6rem; cursor: pointer; }

    /* ---------------------------------------------------- */
    /* 3. DASHBOARD CONTENT */
    /* ---------------------------------------------------- */
    main.container { width: 94%; max-width: 1300px; margin: 35px auto; flex-grow: 1; }

    .welcome-banner { margin-bottom: 35px; }
    .welcome-banner h2 { font-size: 1.9rem; color: var(--secondary); font-weight: 700; }
    .welcome-banner p { color: var(--text-muted); font-size: 1rem; }

    /* --- STATS SECTION --- */
    .stats-grid {
      display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 25px; margin-bottom: 45px;
    }
    .stat-card {
      background: var(--card-bg); padding: 25px; border-radius: 20px;
      display: flex; align-items: center; gap: 20px;
      box-shadow: var(--shadow); border: 1px solid #edf2f7; transition: 0.3s;
    }
    .stat-card:hover { transform: translateY(-5px); box-shadow: 0 15px 35px rgba(0,0,0,0.08); }
    .stat-icon { width: 55px; height: 55px; border-radius: 15px; display: flex; align-items: center; justify-content: center; font-size: 1.4rem; }
    .stat-info h3 { font-size: 1.7rem; font-weight: 700; color: var(--secondary); line-height: 1.2; }
    .stat-info p { font-size: 0.85rem; color: var(--text-muted); font-weight: 500; text-transform: uppercase; letter-spacing: 0.5px; }

    /* --- SECTION HEADERS --- */
    .section-header {
      display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 15px;
      margin-bottom: 25px; padding: 0 5px;
    }
    .section-header h2 { font-size: 1.4rem; font-weight: 700; color: var(--secondary); position: relative; padding-left: 18px; }
    .section-header h2::before { content: ''; position: absolute; left: 0; top: 15%; height: 70%; width: 5px; background: var(--primary); border-radius: 10px; }

    /* --- TABLE STYLING --- */
    .data-card {
      background: var(--card-bg); border-radius: 20px; overflow: hidden;
      box-shadow: var(--shadow); border: 1px solid #edf2f7; margin-bottom: 50px;
    }

    table { width: 100%; border-collapse: collapse; }
    table th {
      background: #f8fafc; padding: 18px 20px; text-align: left;
      font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1.2px;
      color: var(--text-muted); border-bottom: 1px solid #edf2f7;
    }
    table td { padding: 18px 20px; border-bottom: 1px solid #f1f5f9; font-size: 0.92rem; vertical-align: middle; }
    table tr:hover { background-color: #fcfdfe; }

    /* Status Pills */
    .status { padding: 6px 14px; border-radius: 30px; font-size: 0.75rem; font-weight: 600; display: inline-block; text-transform: capitalize; text-align: center; }
    .status-pending { background: #fff9db; color: #f08c00; }
    .status-approved { background: #e3f2fd; color: #1976d2; }
    .status-ongoing { background: #e6fcf5; color: #0ca678; }
    .status-completed { background: #f1f3f5; color: #495057; }
    .status-rejected { background: #fff5f5; color: #fa5252; }
    .status-maintenance { background: #e2e8f0; color: #4a5568; }

    /* Action Buttons */
    .btn {
      padding: 9px 18px; border-radius: 10px; font-size: 0.82rem; font-weight: 600;
      cursor: pointer; border: none; transition: 0.3s; text-decoration: none;
      display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    }
    .btn-add { background: var(--secondary); color: #fff; box-shadow: 0 4px 10px rgba(30, 30, 47, 0.2); }
    .btn-add:hover { background: #000; transform: translateY(-2px); }
    .btn-download { background: #fff; color: var(--secondary); border: 1.5px solid #cbd5e0; }
    .btn-download:hover { background: #f8fafc; border-color: var(--secondary); }

    /* New Coupon Style Button */
    .btn-coupon { background: #fff; color: var(--primary); border: 1.5px solid var(--primary); }
    .btn-coupon:hover { background: var(--primary); color: #fff; }

    .btn-sm { padding: 7px 12px; border-radius: 8px; font-size: 0.75rem; }
    .btn-success { background: var(--success); color: #fff; }
    .btn-danger { background: var(--danger); color: #fff; }
    .btn-info { background: var(--info); color: #fff; }
    .btn-warning { background: var(--warning); color: #000; }

    .action-group { display: flex; gap: 8px; flex-wrap: wrap; }

    /* PAGINATION CSS */
    .pagination { display: flex; justify-content: center; align-items: center; gap: 8px; padding: 20px; background: #fff; border-top: 1px solid #edf2f7; flex-wrap: wrap; }
    .page-btn { padding: 8px 14px; border-radius: 8px; background: #f8fafc; color: var(--secondary); border: 1px solid #edf2f7; text-decoration: none; font-weight: 600; transition: 0.3s; font-size: 0.85rem; }
    .page-btn:hover:not(.disabled) { background: var(--primary); color: #fff; border-color: var(--primary); transform: translateY(-2px); }
    .page-btn.active { background: var(--primary); color: #fff; border-color: var(--primary); box-shadow: 0 4px 10px rgba(255, 107, 107, 0.3); }
    .page-btn.disabled { opacity: 0.5; cursor: not-allowed; background: #f1f5f9; color: #cbd5e0; }

    /* ---------------------------------------------------- */
    /* 4. MASTER FOOTER */
    /* ---------------------------------------------------- */
    footer { background: var(--secondary); color: #fff; padding: 50px 6% 30px; margin-top: auto; border-top: 5px solid var(--primary); text-align: left; }
    .footer-container { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 30px; width: 100%; text-align: left;}
    footer h3 { color: var(--primary); margin-bottom: 20px; font-size: 1.3rem; font-weight: 700; text-align: left; }
    footer p, footer li { color: #b2bec3; font-size: 0.9rem; margin-bottom: 12px; line-height: 1.6; text-align: left; }
    footer ul { list-style: none; padding-left: 0; text-align: left;}
    footer a { color: #b2bec3; text-decoration: none; transition: 0.3s; display: inline-block; text-align: left;}
    footer a:hover { color: var(--primary); padding-left: 5px; }

    footer form input, footer form textarea {
      width: 100%; padding: 12px; border-radius: 8px; border: none; background: #2d2d44; color: #fff; margin-bottom: 12px; outline: none; transition: 0.3s;
    }
    footer form input:focus, footer form textarea:focus { background: #353555; box-shadow: 0 0 0 2px var(--primary); }
    footer form button {
      background: var(--primary); width: 100%; padding: 12px; border: none; color: #fff; border-radius: 8px; cursor: pointer; font-weight: 600; transition: 0.3s; text-align: center;
    }
    footer form button:hover { background: var(--primary-dark); transform: scale(1.02); }
    .copyright { text-align: left; margin-top: 40px; padding-top: 20px; border-top: 1px solid #2d2d44; color:#636e72; font-size:0.8rem; }

    /* ---------------------------------------------------- */
    /* 5. RESPONSIVE MAGIC */
    /* ---------------------------------------------------- */
    @media (max-width: 992px) {
      .data-card { background: transparent; box-shadow: none; border: none; padding: 0;}
      table { border: 0; width: 100%; }
      table thead { display: none; }
      table, tbody, tr, td { display: block; width: 100%; }
      table tr { margin-bottom: 20px; background: #fff; border: 1px solid #edf2f7; border-radius: 12px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); padding: 15px; }
      table td { text-align: right; padding: 12px 0 12px 40%; position: relative; border-bottom: 1px dashed #f1f5f9; display: flex; flex-direction: column; align-items: flex-end; justify-content: center; }
      table td:last-child { border-bottom: none; display: flex; justify-content: flex-end; padding-bottom: 0; margin-top: 10px; }
      table td::before { content: attr(data-label); position: absolute; left: 0; top: 12px; font-weight: 700; text-transform: uppercase; font-size: 0.75rem; color: var(--text-muted); text-align: left; width: 35%; }
      .action-group { justify-content: flex-end; width: 100%; gap: 8px;}
    }

    @media (max-width: 768px) {
      header { padding: 10px 5%; }
      .menu-toggle { display: block; }
      nav { display: none; flex-direction: column; position: absolute; top: 60px; left: 0; width: 100%; background: var(--secondary); padding: 25px; box-shadow: 0 10px 20px rgba(0,0,0,0.2); border-top: 1px solid #2d2d44; }
      nav.active { display: flex; }
      .section-header { flex-direction: column; align-items: flex-start; gap: 10px; }
      .btn-add, .btn-download, .btn-coupon { width: 100%; justify-content: center; }
      .stats-grid { grid-template-columns: 1fr; gap: 15px; }
    }
  </style>
</head>
<body>

  <header>
    <h1>Bike<span>Rental</span></h1>
    <button class="menu-toggle" id="menuToggle"><i class="fa-solid fa-bars"></i></button>
    <nav id="navMenu">
      <a href="/">Home</a>
      <a href="/admin/dashboard" class="nav-active">Operations</a>
      <a href="/admin/manage-coupons" style="border: 1px dashed var(--primary);"><i class="fas fa-ticket-alt"></i> Coupons</a>
      <a href="/logout" class="logout-btn"><i class="fas fa-sign-out-alt"></i> Logout</a>
    </nav>
  </header>

  <main class="container">
    
    <div class="welcome-banner">
      <h2>Welcome Back, Admin</h2>
      <p>Here is what is happening with your rental business today.</p>
    </div>

    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
      <h2>Main Dashboard</h2>
      <a href="/admin/analytics" style="background: var(--secondary); color: #fff; padding: 10px 20px; border-radius: 10px; text-decoration: none; font-weight: 600;">
          <i class="fas fa-chart-bar"></i> View Full Analytics
      </a>
    </div>

    <section class="stats-grid">
      <div class="stat-card">
        <div class="stat-icon" style="background: #e3f2fd; color: #1976d2;"><i class="fas fa-motorcycle"></i></div>
        <div class="stat-info">
          <h3><%= typeof allBikesCount !== 'undefined' ? allBikesCount : 0 %></h3>
          <p>Total Fleet</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background: #e6fcf5; color: #0ca678;"><i class="fas fa-route"></i></div>
        <div class="stat-info">
          <h3><%= typeof allBookings !== 'undefined' ? allBookings.filter(b => b.status === 'ongoing').length : 0 %></h3>
          <p>Live Trips</p>
        </div>
      </div>
      <div class="stat-card">
        <div class="stat-icon" style="background: #fff9db; color: #f08c00;"><i class="fas fa-clock"></i></div>
        <div class="stat-info">
          <h3><%= typeof allBookings !== 'undefined' ? allBookings.filter(b => b.status === 'pending').length : 0 %></h3>
          <p>New Inquiries</p>
        </div>
      </div>

      <div class="stat-card">
        <div class="stat-icon" style="background: #f3e5f5; color: #8e24aa;"><i class="fas fa-percent"></i></div>
        <div class="stat-info">
          <h3><%= typeof coupons !== 'undefined' ? coupons.length : 0 %></h3>
          <p>Active Offers</p>
        </div>
      </div>

      <div class="stat-card" style="border-right: 5px solid var(--primary);">
        <div class="stat-icon" style="background: #fff5f5; color: #fa5252;"><i class="fas fa-hand-holding-dollar"></i></div>
        <div class="stat-info">
          <% let totalRev = 0; 
             if(typeof allBookings !== 'undefined') {
                allBookings.filter(b => b.status === 'completed' || b.status === 'ongoing').forEach(b => totalRev += b.totalPrice); 
             }
          %>
          <h3>₹ <%= totalRev %></h3>
          <p>Total Revenue</p>
        </div>
      </div>
    </section>

    <div class="section-header">
        <h2>Bike Inventory</h2>
        <div class="action-group">
            <a class="btn btn-coupon" href="/admin/manage-coupons"><i class="fas fa-gift"></i> Festive Coupons</a>
            <a class="btn btn-add" href="/admin/add-bike"><i class="fas fa-plus"></i> Add New Bike</a>
        </div>
    </div>

    <div class="data-card">
      <% if (!bikes || bikes.length === 0) { %>
        <p style="padding: 40px; text-align: center; color: var(--text-muted); font-style: italic;">Inventory is currently empty.</p>
      <% } else { %>
        <table>
          <thead>
              <tr><th>Bike Name</th><th>Day Rate</th><th>Public Visibility</th><th>Actions</th></tr>
          </thead>
          <tbody>
          <% bikes.forEach(b => { %>
            <tr>
              <td data-label="Bike Name"><div style="font-weight: 700; color: var(--secondary);"><%= b.name %></div></td>
              <td data-label="Day Rate">₹ <%= b.pricePerDay %></td>
              
              <td data-label="Public Visibility">
                  <% if (b.isMaintenance) { %>
                    <span class="status status-maintenance">Under Maintenance</span>
                  <% } else if (b.isAvailable) { %>
                    <span class="status status-ongoing">Listed (Available)</span>
                  <% } else { %>
                    <span class="status status-rejected">On Rent (Hidden)</span>
                  <% } %>
              </td>

              <td data-label="Actions">
                <div class="action-group">
                    <a class="btn btn-sm btn-info save-scroll" href="/admin/edit-bike/<%= b._id %>" title="Edit Bike"><i class="fas fa-pen"></i></a>
                    <form action="/admin/delete-bike/<%= b._id %>" method="POST" style="display:inline;" onsubmit="saveScrollPos(); return confirm('Delete this bike permanently?');">
                      <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash-can"></i></button>
                    </form>
                </div>
              </td>
            </tr>
          <% }) %>
          </tbody>
        </table>

        <% if (typeof totalBikePages !== 'undefined' && totalBikePages > 1) { %>
          <div class="pagination">
              <a href="/admin/dashboard?bikePage=<%= currentBikePage > 1 ? currentBikePage - 1 : 1 %>&page=<%= typeof currentPage !== 'undefined' ? currentPage : 1 %>" class="page-btn <%= currentBikePage === 1 ? 'disabled' : '' %>">
                  <i class="fas fa-chevron-left"></i> Prev
              </a>
              
              <% for(let i = 1; i <= totalBikePages; i++) { %>
                  <a href="/admin/dashboard?bikePage=<%= i %>&page=<%= typeof currentPage !== 'undefined' ? currentPage : 1 %>" class="page-btn <%= currentBikePage === i ? 'active' : '' %>"><%= i %></a>
              <% } %>
              
              <a href="/admin/dashboard?bikePage=<%= currentBikePage < totalBikePages ? currentBikePage + 1 : totalBikePages %>&page=<%= typeof currentPage !== 'undefined' ? currentPage : 1 %>" class="page-btn <%= currentBikePage === totalBikePages ? 'disabled' : '' %>">
                  Next <i class="fas fa-chevron-right"></i>
              </a>
          </div>
        <% } %>
      <% } %>
    </div>

    <div class="section-header">
        <h2>Customer Operations</h2>
        <a href="/admin/export-bookings" class="btn btn-download"><i class="fas fa-file-export"></i> Download CSV</a>
    </div>

    <div class="data-card">
      <% if (!bookings || bookings.length === 0) { %>
        <p style="padding: 40px; text-align: center; color: var(--text-muted);">No booking history found.</p>
      <% } else { %>
        <table>
          <thead>
              <tr>
                <th>Customer Details</th>
                <th>Bike Model</th>
                <th>Trip Schedule</th>
                <th>Payment Info</th> <th>Status</th>
                <th>Operations</th>
              </tr>
          </thead>
          <tbody>
          <% bookings.forEach(bk => { %>
            <tr>
              <td data-label="Customer">
                <div style="font-weight: 600;"><%= bk.user ? bk.user.name : "System User" %></div>
                <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 2px;">
                    <i class="fas fa-envelope" style="margin-right: 5px;"></i><%= bk.user ? bk.user.email : "" %>
                </div>
                <div style="font-size: 0.75rem; color: var(--text-muted); margin-top: 2px;">
                    <i class="fas fa-phone" style="margin-right: 5px;"></i><%= bk.user && (bk.user.mobile || bk.user.phone) ? (bk.user.mobile || bk.user.phone) : "Not Provided" %>
                </div>
              </td>
              
              <td data-label="Bike Model"><div style="font-weight: 500;"><%= bk.bike ? bk.bike.name : "N/A" %></div></td>
              
              <td data-label="Schedule">
                <div style="font-size: 0.8rem; display: flex; flex-direction: column; gap: 4px;">
                  <% if (bk.pickupDateTime && !isNaN(new Date(bk.pickupDateTime))) { %>
                    <span><i class="far fa-calendar-check" style="color: var(--success); width: 18px;"></i> <%= new Date(bk.pickupDateTime).toLocaleString() %></span>
                    <span><i class="far fa-calendar-times" style="color: var(--danger); width: 18px;"></i> <%= new Date(bk.returnDateTime).toLocaleString() %></span>
                  <% } else { %>
                    <span class="text-muted">No Dates Provided</span>
                  <% } %>
                </div>
              </td>

              <td data-label="Payment Info">
                <div style="font-size: 1rem; font-weight: 800; color: var(--secondary); margin-bottom: 5px;">₹ <%= bk.totalPrice %></div>
                
                <% if(bk.paymentStatus === 'paid') { %>
                    <span style="background-color: #e6fcf5; color: #0ca678; padding: 4px 10px; border-radius: 6px; font-size: 0.7rem; font-weight: 700; display: inline-flex; align-items: center; gap: 4px; border: 1px solid #c3fae8;">
                        <i class="fas fa-check-circle"></i> Paid Online
                    </span>
                    <div style="font-size: 0.7rem; color: #94a3b8; margin-top: 4px; font-family: monospace;">TXN: <%= bk.transactionId || 'N/A' %></div>
                <% } else { %>
                    <span style="background-color: #fff9db; color: #f08c00; padding: 4px 10px; border-radius: 6px; font-size: 0.7rem; font-weight: 700; display: inline-flex; align-items: center; gap: 4px; border: 1px solid #ffe066;">
                        <i class="fas fa-hand-holding-dollar"></i> Collect at Counter
                    </span>
                <% } %>
              </td>

              <td data-label="Status">
                  <span class="status status-<%= bk.status %>"><%= bk.status %></span>
              </td>
              
              <td data-label="Operations">
                <div class="action-group">
                  <% if (bk.status === 'pending') { %>
                    <a class="btn btn-sm btn-success save-scroll" href="/admin/approve/<%= bk._id %>"><i class="fas fa-check"></i> Approve</a>
                    <a class="btn btn-sm btn-danger save-scroll" href="/admin/reject/<%= bk._id %>"><i class="fas fa-xmark"></i></a>
                    
                  <% } else if (bk.status === 'approved') { %>
                    <a class="btn btn-sm btn-warning save-scroll" href="/admin/start-trip/<%= bk._id %>" style="color: #000;"><i class="fas fa-motorcycle"></i> Handover</a>
                    <a class="btn btn-sm btn-danger save-scroll" href="/admin/reject/<%= bk._id %>" title="User No Show"><i class="fas fa-user-slash"></i></a>

                  <% } else if (bk.status === 'ongoing') { %>
                    <a class="btn btn-sm btn-info save-scroll" href="/admin/complete-trip/<%= bk._id %>"><i class="fas fa-flag-checkered"></i> Finish Trip</a>

                  <% } else { %>
                    <form action="/admin/delete-booking/<%= bk._id %>" method="POST" style="display:inline;" onsubmit="saveScrollPos(); return confirm('Delete this record?');">
                      <button type="submit" class="btn btn-sm btn-danger"><i class="fas fa-trash-alt"></i></button>
                    </form>
                  <% } %>
                </div>
              </td>
            </tr>
          <% }) %>
          </tbody>
        </table>

        <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
          <div class="pagination">
              <a href="/admin/dashboard?page=<%= currentPage > 1 ? currentPage - 1 : 1 %>&bikePage=<%= typeof currentBikePage !== 'undefined' ? currentBikePage : 1 %>" class="page-btn <%= currentPage === 1 ? 'disabled' : '' %>">
                  <i class="fas fa-chevron-left"></i> Prev
              </a>
              
              <% for(let i = 1; i <= totalPages; i++) { %>
                  <a href="/admin/dashboard?page=<%= i %>&bikePage=<%= typeof currentBikePage !== 'undefined' ? currentBikePage : 1 %>" class="page-btn <%= currentPage === i ? 'active' : '' %>"><%= i %></a>
              <% } %>
              
              <a href="/admin/dashboard?page=<%= currentPage < totalPages ? currentPage + 1 : totalPages %>&bikePage=<%= typeof currentBikePage !== 'undefined' ? currentBikePage : 1 %>" class="page-btn <%= currentPage === totalPages ? 'disabled' : '' %>">
                  Next <i class="fas fa-chevron-right"></i>
              </a>
          </div>
        <% } %>
      <% } %>
    </div>
  </main>

  <footer>
    <div class="footer-container">
      <div class="footer-section">
        <h3>BikeRental</h3>
        <p>Advanced fleet management and real-time booking automation system. Designed for high-performance rental businesses.</p>
        <div class="social-icons" style="display: flex; gap: 15px; margin-top: 25px;">
            <a href="#" style="font-size: 1.3rem;"><i class="fab fa-facebook-square"></i></a>
