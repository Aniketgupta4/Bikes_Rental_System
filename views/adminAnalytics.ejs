<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Business Intelligence Dashboard - BikeRental Pro</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.23/jspdf.plugin.autotable.min.js"></script>

    <style>
        /* ---------------------------------------------------------
           1. PREMIUM DESIGN SYSTEM & SYNCED PALETTE
        --------------------------------------------------------- */
        :root {
            --primary: #ff6b6b;
            --primary-dark: #ee5253;
            --secondary: #1e1e2f;
            --secondary-light: #2d2d44;
            --bg-body: #f4f7fe;
            --card-bg: #ffffff;
            --text-main: #2d3436;
            --text-muted: #636e72;
            --success: #00b894;
            --info: #0984e3;
            --warning: #f1c40f;
            --danger: #d63031;
            --purple: #6c5ce7;
            --shadow: 0 15px 35px rgba(0,0,0,0.06);
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            --radius-xl: 30px;
            --radius-lg: 20px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        
        html, body { overflow-x: hidden; width: 100%; min-height: 100vh; scroll-behavior: smooth; }
        body { background: var(--bg-body); color: var(--text-main); display: flex; flex-direction: column; line-height: 1.6; }

        /* ---------------------------------------------------------
           2. UNIVERSAL NAVBAR 
        --------------------------------------------------------- */
        .navbar {
            background: var(--secondary); padding: 12px 6%;
            display: flex; justify-content: space-between; align-items: center;
            position: sticky; top: 0; z-index: 5000; box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        .navbar .brand { font-size: 1.8rem; font-weight: 700; color: var(--primary); text-decoration: none; letter-spacing: 1px; }
        .navbar .brand span { color: #fff; font-weight: 300; }

        .nav-links { display: flex; gap: 10px; align-items: center; }
        .nav-links a {
            color: #fff; text-decoration: none; padding: 10px 18px; border-radius: 10px;
            font-weight: 500; font-size: 0.9rem; transition: 0.3s ease;
        }
        .nav-links a:hover { background: rgba(255, 107, 107, 0.1); color: var(--primary); }
        .nav-btn { background: var(--primary); color: #fff !important; font-weight: 700; }

        .menu-btn { display: none; cursor: pointer; color: #fff; font-size: 1.6rem; }

        .mobile-overlay {
            position: fixed; top: 0; right: -100%; width: 100%; height: 100%;
            background: var(--secondary); z-index: 6000; transition: 0.5s cubic-bezier(0.77,0,0.175,1);
            display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 25px;
        }
        .mobile-overlay.active { right: 0; }
        .mobile-overlay a { color: #fff; text-decoration: none; font-size: 1.8rem; font-weight: 700; transition: 0.3s; }
        .mobile-overlay a:hover { color: var(--primary); transform: scale(1.1); }
        .close-menu { position: absolute; top: 25px; right: 25px; color: #fff; font-size: 2.2rem; cursor: pointer; }

        /* ---------------------------------------------------------
           3. MAIN CONTAINER & HERO HEADER
        --------------------------------------------------------- */
        main.container { 
            width: 92%; max-width: 1400px; margin: 40px auto; flex: 1;
            animation: slideUpFade 0.8s ease; 
        }
        @keyframes slideUpFade { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        .dashboard-header { 
            margin-bottom: 45px; display: flex; justify-content: space-between; align-items: center;
            flex-wrap: wrap; gap: 20px; padding-bottom: 20px; border-bottom: 2px solid #eee;
        }
        .dashboard-header h2 { font-size: 2.2rem; font-weight: 800; color: var(--secondary); margin: 0; }
        .dashboard-header p { color: var(--text-muted); font-size: 1rem; }

        .action-flex { display: flex; gap: 12px; flex-wrap: wrap; }
        .btn-intel {
            padding: 12px 24px; border-radius: 12px; font-weight: 700; cursor: pointer; transition: var(--transition);
            display: flex; align-items: center; justify-content: center; gap: 10px; font-size: 0.95rem; text-decoration: none; border: none;
        }
        .btn-dl { background: var(--success); color: #fff; box-shadow: 0 8px 20px rgba(0, 184, 148, 0.2); }
        .btn-back { background: var(--white); color: var(--secondary); border: 1.5px solid #ddd; }
        .btn-intel:hover { transform: translateY(-3px); box-shadow: var(--shadow); }

        /* ---------------------------------------------------------
           4. KPI PERFORMANCE CARDS
        --------------------------------------------------------- */
        .stats-grid { 
            display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); 
            gap: 25px; margin-bottom: 50px; 
        }
        .stat-card {
            background: var(--card-bg); padding: 35px 25px; border-radius: var(--radius-lg); 
            box-shadow: var(--shadow); position: relative; overflow: hidden; 
            border: 1px solid #edf2f7; transition: var(--transition);
        }
        .stat-card:hover { transform: translateY(-5px); border-color: var(--primary); }
        
        .stat-card i.bg-icon { position: absolute; right: -10px; bottom: -10px; font-size: 7rem; opacity: 0.04; color: var(--secondary); transform: rotate(-10deg); }
        .stat-card p.label { font-size: 0.8rem; font-weight: 800; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; }
        .stat-card h3.value { font-size: 2.2rem; font-weight: 800; margin-top: 10px; color: var(--secondary); }
        
        .rev-accent { border-bottom: 6px solid var(--primary); }
        .vol-accent { border-bottom: 6px solid var(--info); }
        .succ-accent { border-bottom: 6px solid var(--success); }
        .pend-accent { border-bottom: 6px solid var(--warning); }

        /* ---------------------------------------------------------
           5. DATA VISUALIZATION LAYOUT (100% RESPONSIVE GRID)
        --------------------------------------------------------- */
        .analytics-container { 
            display: grid; 
            grid-template-columns: repeat(2, 1fr); 
            gap: 30px; 
            margin-bottom: 60px; 
        }
        .full-row { grid-column: 1 / -1; }
        
        .chart-surface { 
            background: var(--card-bg); padding: 30px; border-radius: var(--radius-lg); 
            box-shadow: var(--shadow); border: 1px solid #f0f2f5;
            min-height: 400px; display: flex; flex-direction: column;
        }
        .chart-surface h4 { 
            margin-bottom: 25px; font-size: 1.1rem; font-weight: 800; 
            display: flex; align-items: center; gap: 12px; color: var(--secondary); text-transform: uppercase;
        }
        .chart-surface h4 span.icon-box { 
            width: 38px; height: 38px; border-radius: 10px;
            display: flex; align-items: center; justify-content: center; font-size: 1.1rem;
        }
        /* Icon Box Colors */
        .c-red { background: rgba(255, 107, 107, 0.1); color: var(--primary); }
        .c-blue { background: rgba(9, 132, 227, 0.1); color: var(--info); }
        .c-green { background: rgba(0, 184, 148, 0.1); color: var(--success); }
        .c-purple { background: rgba(108, 92, 231, 0.1); color: var(--purple); }
        .c-yellow { background: rgba(241, 196, 15, 0.1); color: var(--warning); }

        .chart-wrapper { flex: 1; position: relative; min-height: 280px; width: 100%; }


        /* ---------------------------------------------------------
           7. ADVANCED RESPONSIVENESS (MOBILE/TABLET)
        --------------------------------------------------------- */
        @media (max-width: 992px) {
            .analytics-container { grid-template-columns: 1fr; } /* Stack charts on tablets/mobile */
            .chart-surface { min-height: 350px; }
        }

        @media (max-width: 768px) {
            .navbar { padding: 15px 5%; }
            .nav-links { display: none; }
            .menu-btn { display: block; }
            .dashboard-header { flex-direction: column; text-align: center; align-items: center; }
            .action-flex { width: 100%; justify-content: center; }
            .btn-intel { width: 100%; }
            .footer-grid { text-align: center; }
            .footer-links h4::after { left: 50%; transform: translateX(-50%); }
            .footer-contact p { justify-content: center; }
        }

        @media (max-width: 480px) {
            .stat-card { padding: 25px; text-align: center; }
            .stat-card h3.value { font-size: 2rem; }
            .container { width: 95%; margin-top: 20px; }
            .chart-surface { padding: 20px; min-height: 300px;}
        }
    </style>
</head>
<body>

    <div id="hiddenRevSource" style="display:none;"><%- typeof monthlyRevenue !== 'undefined' ? monthlyRevenue : '[]' %></div>
    <div id="hiddenBikeSource" style="display:none;"><%- typeof topBikes !== 'undefined' ? topBikes : '[]' %></div>
    <div id="hiddenCouponSource" style="display:none;"><%- typeof couponStats !== 'undefined' ? JSON.stringify(couponStats) : '[]' %></div>
    <div id="hiddenReviewSource" style="display:none;"><%- typeof reviewStats !== 'undefined' ? JSON.stringify(reviewStats) : '[]' %></div>

    <header class="navbar">
        <a href="/admin/dashboard" class="brand">Bike<span>Rental</span></a>
        <div class="menu-btn" onclick="toggleMenu()"><i class="fas fa-bars"></i></div>
        <nav class="nav-links">
            <a href="/admin/dashboard">Main Control</a>
            <a href="/logout" class="nav-btn">Sign Out</a>
        </nav>
    </header>

    <div class="mobile-overlay" id="mobileNav">
        <div class="close-menu" onclick="toggleMenu()"><i class="fas fa-times"></i></div>
        <a href="/admin/dashboard" onclick="toggleMenu()">Dashboard</a>
        <a href="/logout" style="color:var(--primary);">Logout</a>
    </div>

    <main class="container">
        <div class="dashboard-header">
            <div class="title-block">
                <h2>Market Intelligence</h2>
                <p>Strategic analysis, revenue tracking, and operational health.</p>
            </div>
            <div class="action-flex">
                <button onclick="exportIntelReport()" class="btn-intel btn-dl">
                    <i class="fas fa-file-pdf"></i> Generate Full Report
                </button>
                <a href="/admin/dashboard" class="btn-intel btn-back">
                    <i class="fas fa-arrow-left"></i> Operational Hub
                </a>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card rev-accent">
                <i class="fas fa-sack-dollar bg-icon"></i>
                <p class="label">Gross Revenue</p>
                <h3 class="value">₹ <%= (typeof stats !== 'undefined') ? stats.totalRevenue.toLocaleString('en-IN') : '0' %></h3>
            </div>
            <div class="stat-card vol-accent">
                <i class="fas fa-chart-line bg-icon"></i>
                <p class="label">Booking Traffic</p>
                <h3 class="value"><%= (typeof stats !== 'undefined') ? (stats.completed + stats.pending + stats.cancelled) : '0' %></h3>
            </div>
            <div class="stat-card succ-accent">
                <i class="fas fa-bolt bg-icon"></i>
                <p class="label">Trip Success Rate</p>
                <h3 class="value">
                    <% if (typeof stats !== 'undefined' && (stats.completed + stats.cancelled) > 0) { %>
                        <%= ((stats.completed / (stats.completed + stats.cancelled)) * 100).toFixed(1) %>%
                    <% } else { %> 0% <% } %>
                </h3>
            </div>
            <div class="stat-card pend-accent">
                <i class="fas fa-hourglass-half bg-icon"></i>
                <p class="label">Pending Actions</p>
                <h3 class="value" style="color: var(--warning);"><%= (typeof stats !== 'undefined') ? stats.pending : '0' %></h3>
            </div>
        </div>

        <div class="analytics-container">
            
            <div class="chart-surface full-row">
                <h4><span class="icon-box c-red"><i class="fas fa-chart-area"></i></span> Financial Growth Trend</h4>
                <div class="chart-wrapper"><canvas id="revLineChart"></canvas></div>
            </div>

            <div class="chart-surface">
                <h4><span class="icon-box c-secondary"><i class="fas fa-motorcycle" style="color:var(--secondary);"></i></span> Top Fleet Performance</h4>
                <div class="chart-wrapper"><canvas id="fleetBarChart"></canvas></div>
            </div>

            <div class="chart-surface">
                <h4><span class="icon-box c-green"><i class="fas fa-chart-pie"></i></span> Status Distribution</h4>
                <div class="chart-wrapper"><canvas id="statusDonutChart"></canvas></div>
            </div>

            <div class="chart-surface">
                <h4><span class="icon-box c-purple"><i class="fas fa-tags"></i></span> Promo Code Impact</h4>
                <div class="chart-wrapper"><canvas id="couponPieChart"></canvas></div>
            </div>

            <div class="chart-surface">
                <h4><span class="icon-box c-yellow"><i class="fas fa-star"></i></span> Customer Satisfaction</h4>
                <div class="chart-wrapper"><canvas id="reviewBarChart"></canvas></div>
            </div>

        </div>
    </main>

   <%- include('partials/footer') %>

    <script>
        // Menu Controller
        function toggleMenu() { document.getElementById("mobileNav").classList.toggle("active"); }

        // Data Retrieval Logic (Safe Parsing)
        let monthlyRevRaw = [], bikeStatsRaw = [], couponStatsRaw = [], reviewStatsRaw = [];
        try {
            monthlyRevRaw = JSON.parse(document.getElementById('hiddenRevSource').textContent || "[]");
            bikeStatsRaw = JSON.parse(document.getElementById('hiddenBikeSource').textContent || "[]");
            couponStatsRaw = JSON.parse(document.getElementById('hiddenCouponSource').textContent || "[]");
            reviewStatsRaw = JSON.parse(document.getElementById('hiddenReviewSource').textContent || "[]");
        } catch(e) { console.error("Intel Alert: Data Handshake Error", e); }

        // Fallback data if DB is empty for new charts
        if(couponStatsRaw.length === 0) couponStatsRaw = [{_id: "WELCOME100", count: 5}, {_id: "HOLIDAY50", count: 2}];
        if(reviewStatsRaw.length === 0) reviewStatsRaw = [{rating: "5 Star", count: 12}, {rating: "4 Star", count: 6}, {rating: "3 Star", count: 2}];

        // Chart Global Config
        Chart.defaults.font.family = "'Poppins', sans-serif";
        Chart.defaults.color = '#7f8c8d';

        // 1. Line Chart: Revenue
        const revCtx = document.getElementById('revLineChart').getContext('2d');
        const grad = revCtx.createLinearGradient(0, 0, 0, 400);
        grad.addColorStop(0, 'rgba(255, 107, 107, 0.4)'); grad.addColorStop(1, 'rgba(255, 107, 107, 0)');
        new Chart(revCtx, {
            type: 'line',
            data: {
                labels: monthlyRevRaw.map(d => d._id),
                datasets: [{
                    label: 'Gross Revenue (₹)', data: monthlyRevRaw.map(d => d.revenue),
                    borderColor: '#ff6b6b', borderWidth: 4, fill: true, backgroundColor: grad, tension: 0.4, pointRadius: 4, pointBackgroundColor: '#fff'
                }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true } } }
        });

        // 2. Bar Chart: Fleet Score
        new Chart(document.getElementById('fleetBarChart'), {
            type: 'bar',
            data: {
                labels: bikeStatsRaw.map(d => d.bikeDetails ? d.bikeDetails.name.substring(0,15) : 'Unknown'),
                datasets: [{
                    label: 'Success Bookings', data: bikeStatsRaw.map(d => d.count),
                    backgroundColor: '#1e1e2f', borderRadius: 8
                }]
            },
            options: { indexAxis: 'y', responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } } }
        });

        // 3. Donut Chart: Status
        new Chart(document.getElementById('statusDonutChart'), {
            type: 'doughnut',
            data: {
                labels: ['Pending', 'Completed', 'Cancelled'],
                datasets: [{
                    data: [<%= stats.pending || 0 %>, <%= stats.completed || 0 %>, <%= stats.cancelled || 0 %>],
                    backgroundColor: ['#f1c40f', '#00b894', '#d63031'], borderWidth: 0, cutout: '75%', hoverOffset: 10
                }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'bottom' } } }
        });

        // 4. NEW Doughnut Chart: Coupon Usage
        new Chart(document.getElementById('couponPieChart'), {
            type: 'doughnut',
            data: {
                labels: couponStatsRaw.map(d => d._id),
                datasets: [{
                    data: couponStatsRaw.map(d => d.count),
                    backgroundColor: ['#6c5ce7', '#a29bfe', '#74b9ff', '#0984e3', '#81ecec'],
                    borderWidth: 2, borderColor: '#fff', cutout: '65%'
                }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { position: 'right' } } }
        });

        // 5. NEW Bar Chart: Reviews
        new Chart(document.getElementById('reviewBarChart'), {
            type: 'bar',
            data: {
                labels: reviewStatsRaw.map(d => d.rating),
                datasets: [{
                    label: 'Number of Reviews', data: reviewStatsRaw.map(d => d.count),
                    backgroundColor: '#f1c40f', borderRadius: 6
                }]
            },
            options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { y: { beginAtZero: true, ticks: {stepSize: 1} } } }
        });

        // ---------------------------------------------------------
        // ADVANCED PDF REPORT ENGINE (WITH NEW SECTIONS)
        // ---------------------------------------------------------
        function exportIntelReport() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            
            // Branding Header
            doc.setFillColor(30, 30, 47);
            doc.rect(0, 0, 210, 40, 'F');
            doc.setTextColor(255, 255, 255);
            doc.setFontSize(22);
            doc.text("BIKERENTAL PRO INTELLIGENCE", 15, 22);
            doc.setFontSize(9);
            doc.text(`Official Analytics Report | Exported: ${new Date().toLocaleString()}`, 15, 32);

            // 1. KPI Performance
            doc.setTextColor(30, 30, 47);
            doc.setFontSize(14);
            doc.text("1. Operational Summary", 15, 55);

            const kpiTable = [
                ["Metric", "Value"],
                ["Total Gross Revenue", "INR <%= stats.totalRevenue.toLocaleString('en-IN') %>"],
                ["Completed Rides", "<%= stats.completed %>"],
                ["Pending Action", "<%= stats.pending %>"],
                ["Cancelled Rides", "<%= stats.cancelled %>"]
            ];
            doc.autoTable({ startY: 60, head: [kpiTable[0]], body: kpiTable.slice(1), theme: 'striped', headStyles: { fillColor: [255, 107, 107] } });

            // 2. Fleet Analytics Table
            let currentY = doc.lastAutoTable.finalY + 15;
            doc.text("2. Top Fleet Performance", 15, currentY);
            const fleetTable = bikeStatsRaw.map(b => [b.bikeDetails ? b.bikeDetails.name : 'Unknown', b.count.toString() + " Trips"]);
            doc.autoTable({ startY: currentY + 5, head: [['Motorcycle Model', 'Total Successful Rentals']], body: fleetTable, theme: 'grid', headStyles: { fillColor: [30, 30, 47] } });

            // 3. Coupon Analytics Table
            currentY = doc.lastAutoTable.finalY + 15;
            // Check page break
            if (currentY > 250) { doc.addPage(); currentY = 20; }
            
            doc.text("3. Promotional Code Impact", 15, currentY);
            const cpTable = couponStatsRaw.map(c => [c._id, c.count.toString() + " Times Used"]);
            doc.autoTable({ startY: currentY + 5, head: [['Coupon Code', 'Usage Frequency']], body: cpTable, theme: 'grid', headStyles: { fillColor: [108, 92, 231] } });

            // Confidential Stamp
            const totalPages = doc.internal.getNumberOfPages();
            for(let i = 1; i <= totalPages; i++) {
                doc.setPage(i);
                doc.setFontSize(8);
                doc.setTextColor(150, 150, 150);
                doc.text("CLASSIFIED DOCUMENT: Generated via BikeRental BI Module (Aniket Kumar Gupta).", 105, 290, {align: "center"});
            }

            doc.save(`BikeRental_Analytics_Report_${Date.now()}.pdf`);
        }
    </script>
</body>
</html>