<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>BikeRental - Ride Your Way</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        /* ----------------------- 1. DESIGN SYSTEM ----------------------- */
        :root {
            --primary: #ff6b6b;
            --primary-dark: #ee5253;
            --secondary: #1e1e2f;
            --bg-body: #f8fafc;
            --card-bg: #ffffff;
            --text-main: #2d3436;
            --text-muted: #636e72;
            --success: #00b894;
            --warning: #f1c40f; 
            --danger: #d63031;
            --shadow-sm: 0 5px 15px rgba(0,0,0,0.05);
            --shadow-md: 0 15px 35px rgba(0,0,0,0.08);
            --transition: all 0.3s ease;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        html, body { overflow-x: hidden; width: 100%; scroll-behavior: smooth; }
        body { background: var(--bg-body); color: var(--text-main); display: flex; flex-direction: column; min-height: 100vh; }

        /* ----------------------- 2. MODERN NAVBAR ----------------------- */
        .navbar {
            background: var(--secondary); padding: 15px 6%;
            display: flex; justify-content: space-between; align-items: center;
            position: sticky; top: 0; z-index: 2000; box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        .navbar .brand { font-size: 1.8rem; font-weight: 800; color: var(--primary); text-decoration: none; letter-spacing: 1px; }
        .navbar .brand span { color: #fff; font-weight: 300; }

        .nav-links { display: flex; gap: 15px; align-items: center; }
        .nav-links a { color: #fff; text-decoration: none; padding: 10px 18px; border-radius: 10px; font-weight: 500; font-size: 0.95rem; transition: var(--transition); }
        .nav-links a:hover { background: rgba(255, 107, 107, 0.1); color: var(--primary); }
        .nav-btn { background: var(--primary); color: #fff !important; }
        .nav-btn:hover { background: var(--primary-dark) !important; transform: translateY(-2px); }

        .menu-btn { display: none; cursor: pointer; color: #fff; font-size: 1.6rem; padding: 5px; }

        /* Mobile Menu Overlay */
        .mobile-overlay {
            position: fixed; top: 0; right: -100%; width: 100%; height: 100%;
            background: rgba(30, 30, 47, 0.98); backdrop-filter: blur(10px); z-index: 6000; transition: right 0.4s cubic-bezier(0.77, 0, 0.175, 1);
            display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 25px;
        }
        .mobile-overlay.active { right: 0; }
        .mobile-overlay a { color: #fff; text-decoration: none; font-size: 1.6rem; font-weight: 600; transition: var(--transition); }
        .mobile-overlay a:hover { color: var(--primary); transform: scale(1.05); }
        .close-menu { position: absolute; top: 30px; right: 30px; color: #fff; font-size: 2.5rem; cursor: pointer; }

        /* ----------------------- 3. HERO SECTION ----------------------- */
        .hero {
            background: linear-gradient(rgba(30, 30, 47, 0.75), rgba(30, 30, 47, 0.85)), 
                        url('https://images.unsplash.com/photo-1558981806-ec527fa84c39?auto=format&fit=crop&w=1350&q=80');
            background-size: cover; background-position: center;
            color: #fff; text-align: center; padding: clamp(60px, 10vh, 140px) 20px;
            padding-bottom: 120px; 
        }
        .hero h1 { font-size: clamp(2.2rem, 5vw, 3.8rem); font-weight: 800; text-transform: uppercase; margin-bottom: 15px; letter-spacing: 1px; }
        .hero p { font-size: clamp(0.95rem, 2vw, 1.1rem); max-width: 800px; margin: 0 auto; opacity: 0.9; line-height: 1.6; }

        /* ----------------------- 4. FANG-STYLE SEARCH & FILTERS ----------------------- */
        .search-filter-container {
            width: 90%; max-width: 1000px; margin: -50px auto 50px;
            position: relative; z-index: 100;
        }

        /* Prominent Search Bar */
        .main-search-box {
            background: #fff; padding: 10px; border-radius: 16px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.12); display: flex; align-items: center;
            margin-bottom: 20px; border: 2px solid transparent; transition: var(--transition);
        }
        .main-search-box:focus-within { border-color: var(--primary); box-shadow: 0 15px 35px rgba(255, 107, 107, 0.15); }
        .main-search-box i { color: var(--primary); font-size: 1.3rem; margin-left: 15px; margin-right: 15px; }
        .main-search-box input {
            flex: 1; border: none; outline: none; font-size: 1rem; width: 100%;
            color: var(--secondary); font-family: inherit; font-weight: 500;
        }
        .main-search-box button {
            background: var(--primary); color: #fff; border: none; padding: 14px 30px;
            border-radius: 12px; font-weight: 700; font-size: 1rem; cursor: pointer; transition: 0.3s;
        }
        .main-search-box button:hover { background: var(--primary-dark); }

        /* Secondary Filters Box */
        .advanced-filters-box {
            background: var(--card-bg); border-radius: 16px; padding: 25px;
            box-shadow: var(--shadow-sm); border: 1px solid #edf2f7;
        }
        
        .filter-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .filter-header h4 { font-size: 1.1rem; color: var(--secondary); font-weight: 800; margin: 0; display: flex; align-items: center; gap: 8px;}
        .clear-filters-btn { font-size: 0.85rem; color: var(--danger); font-weight: 600; text-decoration: none; background: #fff5f5; padding: 6px 12px; border-radius: 8px; transition: var(--transition); }
        .clear-filters-btn:hover { background: var(--danger); color: #fff; }

        .filter-grid { display: grid; grid-template-columns: repeat(3, 1fr) auto; gap: 20px; align-items: flex-end; }
        
        .filter-group { display: flex; flex-direction: column; gap: 8px; }
        .filter-group label { font-size: 0.75rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; }
        
        .filter-input {
            width: 100%; padding: 12px 15px; border-radius: 10px; border: 2px solid #e2e8f0;
            font-size: 0.95rem; font-family: inherit; outline: none; transition: 0.3s; 
            background: #f8fafc; color: var(--secondary); font-weight: 500;
        }
        .filter-input:focus { border-color: var(--primary); background: #fff; }
        select.filter-input { cursor: pointer; appearance: auto; }

        /* Range Slider */
        .range-label { display: flex; justify-content: space-between; align-items: center; }
        .range-value { font-weight: 800; color: var(--primary); font-size: 0.95rem; }
        input[type=range] { -webkit-appearance: none; width: 100%; background: transparent; padding: 10px 0; }
        input[type=range]::-webkit-slider-thumb { -webkit-appearance: none; height: 20px; width: 20px; border-radius: 50%; background: var(--primary); cursor: pointer; margin-top: -7px; box-shadow: 0 2px 5px rgba(0,0,0,0.2); }
        input[type=range]::-webkit-slider-runnable-track { width: 100%; height: 6px; cursor: pointer; background: #e2e8f0; border-radius: 5px; }

        .filter-btn {
            background: var(--secondary); color: #fff; border: none; padding: 12px 25px; border-radius: 10px;
            font-weight: 700; font-size: 0.95rem; cursor: pointer; transition: 0.3s; height: 46px; white-space: nowrap;
        }
        .filter-btn:hover { background: var(--primary); }

        /* ----------------------- 5. BIKE GRID & CARDS ----------------------- */
        .container { width: 90%; max-width: 1250px; margin: auto; padding: 20px 0 60px; flex: 1; }
        .section-header { text-align: center; margin-bottom: 40px; }
        .section-header h2 { font-size: clamp(2rem, 4vw, 2.5rem); color: var(--secondary); font-weight: 800; }
        .section-header span { color: var(--primary); }

        .bike-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }

        .bike-card {
            background: var(--card-bg); border-radius: 20px; overflow: hidden;
            box-shadow: var(--shadow-sm); transition: transform 0.3s ease, box-shadow 0.3s ease; 
            display: flex; flex-direction: column; border: 1px solid #edf2f7;
        }
        .bike-card:hover { transform: translateY(-8px); box-shadow: 0 15px 35px rgba(0,0,0,0.1); }

        .img-wrapper { width: 100%; height: 220px; overflow: hidden; position: relative; background: #f1f5f9; }
        .img-wrapper img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
        .bike-card:hover .img-wrapper img { transform: scale(1.05); }
        
        .badge {
            position: absolute; top: 15px; left: 15px; padding: 6px 14px; border-radius: 25px;
            font-size: 0.75rem; font-weight: 700; color: #fff; text-transform: uppercase; z-index: 10;
            display: flex; align-items: center; gap: 6px; box-shadow: 0 4px 10px rgba(0,0,0,0.15);
        }
        .badge-available { background: var(--success); }
        .badge-booked { background: var(--danger); }
        .badge-maintenance { background: #718096; } 

        .card-content { padding: 25px; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        
        .title-row { display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px; }
        .title-row h3 { font-size: 1.4rem; font-weight: 800; color: var(--secondary); margin: 0; line-height: 1.2; }
        
        .rating-badge {
            background: rgba(241, 196, 15, 0.1); color: #d4ac0d; font-size: 0.85rem; font-weight: 700; 
            padding: 4px 10px; border-radius: 8px; display: flex; align-items: center; gap: 5px;
            border: 1px solid rgba(241, 196, 15, 0.3);
        }

        .card-content .price { font-size: 1.2rem; font-weight: 800; color: var(--primary); margin-bottom: 20px; }

        .btn-book {
            width: 100%; padding: 14px; border-radius: 12px; border: none;
            background: var(--secondary); color: #fff; font-weight: 700; text-decoration: none;
            text-align: center; transition: 0.3s; font-size: 1rem; display: block;
        }
        .btn-book:hover:not(.disabled) { background: var(--primary); transform: translateY(-2px); box-shadow: 0 5px 15px rgba(255, 107, 107, 0.3); }
        .btn-book.disabled { background: #cbd5e0; color: #718096; cursor: not-allowed; pointer-events: none; }
        .btn-book.maintenance-btn { background: #e2e8f0; color: #4a5568; }

        /* ----------------------- 6. UNIVERSAL FOOTER ----------------------- */
        footer { background: var(--secondary); color: #fff; padding: 80px 6% 40px; margin-top: auto; border-top: 6px solid var(--primary); }
        .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 50px; max-width: 1250px; margin: 0 auto; }
        .footer-brand h3 { color: var(--primary); font-size: 2rem; font-weight: 800; margin-bottom: 20px; }
        .footer-brand p { color: #cbd5e0; font-size: 0.95rem; line-height: 1.8; }
        .social-icons { display: flex; gap: 15px; margin-top: 20px; }
        .social-icons a { color: var(--primary); font-size: 1.3rem; transition: 0.3s; }
        .social-icons a:hover { color: #fff; transform: translateY(-3px); }
        .footer-links h4 { color: #fff; margin-bottom: 25px; font-size: 1.2rem; }
        .footer-links ul { list-style: none; }
        .footer-links a { color: #cbd5e0; text-decoration: none; display: block; margin-bottom: 12px; font-size: 0.95rem; transition: 0.3s; }
        .footer-links a:hover { color: var(--primary); padding-left: 8px; }
        .footer-contact p { color: #cbd5e0; font-size: 0.95rem; margin-bottom: 15px; display: flex; align-items: center; gap: 12px; }
        .footer-contact i { color: var(--primary); width: 20px; }
        .footer-form input, .footer-form textarea { width: 100%; padding: 12px; border-radius: 10px; border: none; background: #2d2d44; color: #fff; margin-bottom: 12px; outline: none; font-family: inherit; }
        .footer-form button { width: 100%; padding: 12px; background: var(--primary); color: #fff; border: none; border-radius: 10px; font-weight: 700; cursor: pointer; transition: 0.3s; }
        .footer-form button:hover { background: var(--primary-dark); }
        .copyright { text-align: center; padding-top: 40px; margin-top: 60px; border-top: 1px solid #2d2d44; color: #636e72; font-size: 0.85rem; }

        /* ----------------------- 7. STRICT RESPONSIVE QUERIES ----------------------- */
        @media (max-width: 1024px) { 
            .filter-grid { grid-template-columns: 1fr 1fr; gap: 20px; } 
            .filter-btn-group { grid-column: span 2; }
            .filter-btn { width: 100%; }
        }
        @media (max-width: 900px) { .nav-links { display: none; } .menu-btn { display: block; } }
        
        /* Mobile Specific Overrides */
        @media (max-width: 600px) {
            .navbar { padding: 15px 5%; }
            .search-filter-container { width: 95%; margin-top: -30px; }
            
            /* Fix Search Bar Overflow */
            .main-search-box { padding: 8px; flex-wrap: nowrap; }
            .main-search-box input { font-size: 0.95rem; padding: 5px; width: 100%; }
            .main-search-box i { margin-left: 10px; margin-right: 10px; }
            .main-search-box button { padding: 12px 20px; font-size: 0.9rem; }
            
            /* Fix Filters Box Overflow */
            .advanced-filters-box { padding: 20px 15px; }
            .filter-grid { grid-template-columns: 1fr; gap: 15px; } 
            .filter-btn-group { grid-column: span 1; }
            .bike-grid { grid-template-columns: 1fr; padding: 0; }
        }

        /* ----------------------- 8. CHATBOT CSS ----------------------- */
        #chat-fab {
            position: fixed; bottom: 30px; right: 30px; z-index: 5000;
            width: 60px; height: 60px; border-radius: 50%; background: var(--primary); color: #fff;
            border: none; font-size: 1.6rem; cursor: pointer;
            box-shadow: 0 5px 20px rgba(255,107,107,0.4); transition: transform 0.3s ease, background 0.3s;
            display: flex; align-items: center; justify-content: center;
        }
        #chat-fab:hover { transform: scale(1.1); background: var(--primary-dark); }
        #chat-window {
            position: fixed; bottom: 100px; right: 30px; z-index: 5000;
            width: 360px; height: 480px; max-width: calc(100% - 40px); max-height: 70vh;
            background: #fff; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.15);
            display: none; flex-direction: column; overflow: hidden; border: 1px solid #edf2f7;
        }
        #chat-window.open { display: flex; animation: slideUpChat 0.4s ease; }
        @keyframes slideUpChat { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
        .chat-header { background: var(--secondary); color: #fff; padding: 16px 20px; display: flex; justify-content: space-between; align-items: center; }
        .chat-header h3 { margin: 0; font-size: 1.05rem; font-weight: 600; }
        .chat-close { background: none; border: none; color: rgba(255,255,255,0.7); font-size: 1.8rem; cursor: pointer; line-height: 1; transition: 0.2s; }
        .chat-close:hover { color: #fff; }
        .chat-body { flex: 1; padding: 18px; overflow-y: auto; background: #f9f9ff; display: flex; flex-direction: column; gap: 12px; }
        .chat-msg { padding: 12px 16px; border-radius: 14px; max-width: 85%; font-size: 0.9rem; line-height: 1.5; }
        .msg-bot { background: #fff; border: 1px solid #edf2f7; align-self: flex-start; border-bottom-left-radius: 4px; color: #2d3436; }
        .msg-user { background: var(--primary); color: #fff; align-self: flex-end; border-bottom-right-radius: 4px; }
        .chat-input-container { display: flex; padding: 15px; background: #fff; border-top: 1px solid #edf2f7; align-items: center;}
        .chat-input-container input { flex: 1; padding: 12px 15px; border: 1px solid #edf2f7; border-radius: 10px; outline: none; font-size: 0.9rem; transition: 0.3s; }
        .chat-input-container input:focus { border-color: var(--primary); }
        .chat-input-container button { background: none; border: none; color: var(--primary); font-size: 1.4rem; cursor: pointer; margin-left: 12px; transition: 0.3s; }
        .chat-input-container button:hover { color: var(--primary-dark); }
        @media (max-width: 480px) { #chat-window { right: 20px; bottom: 90px; width: calc(100% - 40px); } #chat-fab { right: 20px; bottom: 20px; } }
    </style>
</head>
<body>

    <header class="navbar">
        <a href="/" class="brand">Bike<span>Rental</span></a>
        <div class="menu-btn" onclick="toggleMenu()"><i class="fas fa-bars"></i></div>
        <nav class="nav-links">
            <% if (typeof user === 'undefined' || !user) { %>
                <a href="/login">Login</a>
                <a href="/signup" class="nav-btn">Signup</a>
            <% } else { %>
                <a href="<%= user.role === 'admin' ? '/admin/dashboard' : '/user/dashboard' %>">Dashboard</a>
                <a href="/logout" class="nav-btn">Logout</a>
            <% } %>
        </nav>
    </header>

    <div class="mobile-overlay" id="mobileNav">
        <div class="close-menu" onclick="toggleMenu()"><i class="fas fa-times"></i></div>
        <% if (typeof user === 'undefined' || !user) { %>
            <a href="/login" onclick="toggleMenu()">Login</a>
            <a href="/signup" onclick="toggleMenu()">Signup</a>
        <% } else { %>
            <a href="<%= user.role === 'admin' ? '/admin/dashboard' : '/user/dashboard' %>" onclick="toggleMenu()">Dashboard</a>
            <a href="/logout" onclick="toggleMenu()">Logout</a>
        <% } %>
    </div>

    <section class="hero">
        <div class="container" style="padding: 0;">
            <h1>Premium Rides, Simplified.</h1>
            <p>Find the perfect bike for your journey with our advanced search and filters.</p>
        </div>
    </section>

    <div class="search-filter-container">
        
        <form action="/" method="GET">
            
            <div class="main-search-box">
                <i class="fas fa-search"></i>
                <input type="text" name="search" placeholder="Search your dream ride (e.g. Duke, R15)..." value="<%= typeof filters !== 'undefined' && filters.search ? filters.search : '' %>">
                <button type="submit">Search</button>
            </div>

            <div class="advanced-filters-box">
                <div class="filter-header">
                    <h4><i class="fas fa-sliders-h" style="color: var(--primary); margin-right: 8px;"></i> Filters</h4>
                    <% if (typeof filters !== 'undefined' && (filters.search || filters.maxPrice < 2500 || filters.rating !== '0' || (filters.status && filters.status !== 'all'))) { %>
                        <a href="/" class="clear-filters-btn"><i class="fas fa-times"></i> Clear Filters</a>
                    <% } %>
                </div>

                <div class="filter-grid">
                    
                    <div class="filter-group">
                        <div class="range-label">
                            <label>Max Price</label>
                            <span class="range-value" id="priceDisplay">₹ <%= typeof filters !== 'undefined' && filters.maxPrice ? filters.maxPrice : '2500' %></span>
                        </div>
                        <input type="range" name="maxPrice" id="priceSlider" min="500" max="2500" step="100" value="<%= typeof filters !== 'undefined' && filters.maxPrice ? filters.maxPrice : '2500' %>" oninput="document.getElementById('priceDisplay').innerText = '₹ ' + this.value">
                    </div>

                    <div class="filter-group">
                        <label>Minimum Rating</label>
                        <select name="rating" class="filter-input">
                            <option value="0" <%= typeof filters !== 'undefined' && filters.rating == '0' ? 'selected' : '' %>>Any Rating</option>
                            <option value="4" <%= typeof filters !== 'undefined' && filters.rating == '4' ? 'selected' : '' %>>4+ Stars ⭐⭐⭐⭐</option>
                            <option value="3" <%= typeof filters !== 'undefined' && filters.rating == '3' ? 'selected' : '' %>>3+ Stars ⭐⭐⭐</option>
                        </select>
                    </div>

                    <div class="filter-group">
                        <label>Availability</label>
                        <select name="status" class="filter-input">
                            <option value="all" <%= typeof filters !== 'undefined' && filters.status == 'all' ? 'selected' : '' %>>Show All Fleet</option>
                            <option value="available" <%= typeof filters !== 'undefined' && filters.status == 'available' ? 'selected' : '' %>>Available Now</option>
                        </select>
                    </div>

                    <div class="filter-group filter-btn-group">
                        <button type="submit" class="filter-btn"><i class="fas fa-check"></i> Apply</button>
                    </div>

                </div>
            </div>

        </form>
    </div>

    <main class="container" style="padding-top: 0;">
        <div class="section-header">
            <h2>Explore Our <span>Fleet</span></h2>
        </div>
        
        <div class="bike-grid">
            <% if (typeof bikes === 'undefined' || !bikes || bikes.length === 0) { %>
                <div style="grid-column: 1/-1; text-align: center; padding: 60px 20px; background: #fff; border-radius: 20px; border: 2px dashed #edf2f7;">
                    <i class="fas fa-search-minus fa-4x" style="color: #cbd5e0; margin-bottom: 20px;"></i>
                    <h3 style="color: var(--secondary); font-size: 1.5rem; margin-bottom: 10px;">No bikes found</h3>
                    <p style="color: var(--text-muted); font-size: 1rem; margin-bottom: 20px;">Try adjusting your filters or search term to find available rides.</p>
                    <a href="/" style="display: inline-block; padding: 12px 25px; background: var(--primary); color: #fff; border-radius: 10px; font-weight: 600; text-decoration: none;">Clear All Filters</a>
                </div>
            <% } else { %>
                <% bikes.forEach(b => { %>
                    <div class="bike-card">
                        <div class="img-wrapper">
                            <% if (b.isMaintenance) { %>
                                <span class="badge badge-maintenance"><i class="fas fa-tools"></i> In Service</span>
                            <% } else if (!b.isCurrentlyRented && b.isAvailable) { %>
                                <span class="badge badge-available"><i class="fas fa-check-circle"></i> Available</span>
                            <% } else { %>
                                <span class="badge badge-booked"><i class="fas fa-lock"></i> Booked</span>
                            <% } %>
                            <img src="<%= b.image ? b.image : 'https://via.placeholder.com/400x250?text=No+Image' %>" alt="<%= b.name %>">
                        </div>

                        <div class="card-content">
                            <div>
                                <div class="title-row">
                                    <h3><%= b.name %></h3>
                                    <% if (b.averageRating && b.averageRating > 0) { %>
                                        <div class="rating-badge" title="<%= b.reviews ? b.reviews.length : 0 %> Reviews">
                                            <i class="fas fa-star"></i> <%= b.averageRating %>
                                        </div>
                                    <% } else { %>
                                        <div class="rating-badge" style="color: #94a3b8; border-color: #cbd5e0; background: #f8fafc;" title="No Reviews Yet">
                                            <i class="far fa-star"></i> New
                                        </div>
                                    <% } %>
                                </div>
                                <p class="price">₹ <%= b.pricePerDay %> <small style="font-weight: 400; color: var(--text-muted);">/ Day</small></p>
                            </div>

                            <% if (b.isMaintenance) { %>
                                <button class="btn-book disabled maintenance-btn" disabled><i class="fas fa-wrench"></i> Maintenance</button>
                            <% } else if (!b.isCurrentlyRented && b.isAvailable) { %>
                                <a class="btn-book" href="/bike/<%= b._id %>">Rent Now</a>
                            <% } else { %>
                                <button class="btn-book disabled" disabled>Unavailable</button>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </main>

    <footer>
        <div class="footer-grid">
            <div class="footer-brand">
                <h3>BikeRental</h3>
                <p>Ride with confidence. Premium quality bikes, sanitized and ready for your adventure.</p>
            </div>
            <div class="footer-links">
                <h4>Shortcuts</h4>
                <ul>
                    <li><a href="/">Browse Bikes</a></li>
                    <li><a href="/login">User Access</a></li>
                </ul>
            </div>
            <div class="footer-links">
                <h4>Support</h4>
                <p style="color:#b2bec3;"><i class="fas fa-envelope" style="color:var(--primary); margin-right:10px;"></i> support@bikerental.com</p>
                <p style="color:#b2bec3; margin-top:10px;"><i class="fas fa-phone" style="color:var(--primary); margin-right:10px;"></i> +91 98765 43210</p>
            </div>
            <div class="footer-links">
                <h4>Feedback</h4>
                <form action="/feedback" method="POST" style="display:flex; flex-direction:column; gap:10px;">
                    <input type="text" placeholder="Name" required style="padding:10px; border-radius:8px; border:none; background:#2d2d44; color:#fff;">
                    <textarea placeholder="Message" rows="2" required style="padding:10px; border-radius:8px; border:none; background:#2d2d44; color:#fff;"></textarea>
                    <button type="submit" style="padding:10px; background:var(--primary); color:#fff; border:none; border-radius:8px; font-weight:700; cursor:pointer;">Send</button>
                </form>
            </div>
        </div>
        <div class="copyright">
            <p>© <%= new Date().getFullYear() %> BikeRental | Developed by Aniket Kumar Gupta</p>
        </div>
    </footer>

    <button id="chat-fab"><i class="fas fa-comment-dots"></i></button>
    <div id="chat-window">
        <div class="chat-header">
            <h3><i class="fas fa-motorcycle"></i> Assistant</h3>
            <button onclick="document.getElementById('chat-window').classList.remove('open')">&times;</button>
        </div>
        <div class="chat-body" id="chat-body">
            <div class="chat-msg msg-bot">
                <% if (typeof user !== 'undefined' && user) { %> Hi <%= user.name %>! How can I help you today? <% } else { %> Hi! Please Login to ask me about bikes! <% } %>
            </div>
        </div>
        <div class="chat-input-container">
            <% if (typeof user !== 'undefined' && user) { %>
                <input type="text" id="chat-input" placeholder="Type here...">
                <button id="chat-send" style="background:none; border:none; color:var(--primary); font-size:1.2rem;"><i class="fas fa-paper-plane"></i></button>
            <% } else { %>
                <a href="/login" style="color:var(--primary); text-decoration:none; font-weight:700;">Login to Chat</a>
            <% } %>
        </div>
    </div>



    <script>
        function toggleMenu() { 
            const menu = document.getElementById("mobileNav");
            menu.classList.toggle("active");
            document.body.style.overflow = menu.classList.contains("active") ? "hidden" : "auto";
        }

        const chatFab = document.getElementById('chat-fab');
        if(chatFab) {
            chatFab.onclick = () => document.getElementById('chat-window').classList.toggle('open');
        }

        const isLoggedIn = <%= typeof user !== 'undefined' && user ? 'true' : 'false' %>;
        if (isLoggedIn) {
            const chatInput = document.getElementById('chat-input');
            const chatSend = document.getElementById('chat-send');
            const chatBody = document.getElementById('chat-body');

            async function sendMessage() {
                const text = chatInput.value.trim();
                if (!text) return;
                const userDiv = document.createElement('div');
                userDiv.className = 'chat-msg msg-user';
                userDiv.innerText = text;
                chatBody.appendChild(userDiv);
                chatInput.value = '';
                chatBody.scrollTop = chatBody.scrollHeight;

                try {
                    const res = await fetch('/api/chat', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ message: text })
                    });
                    const data = await res.json();
                    const botDiv = document.createElement('div');
                    botDiv.className = 'chat-msg msg-bot';
                    botDiv.innerHTML = data.reply.replace(/\*\*(.*?)\*\*/g, '<b>$1</b>');
                    chatBody.appendChild(botDiv);
                    chatBody.scrollTop = chatBody.scrollHeight;
                } catch (e) { console.error(e); }
            }

            chatSend.onclick = sendMessage;
            chatInput.onkeypress = (e) => { if (e.key === 'Enter') sendMessage(); };
        }
    </script>
</body>
</html>