<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>BikeRental - Ride Your Way</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        /* ----------------------- 1. DESIGN SYSTEM ----------------------- */
        :root {
            --primary: #ff6b6b;
            --primary-dark: #ee5253;
            --secondary: #1e1e2f;
            --bg-body: #f4f7fe;
            --card-bg: #ffffff;
            --text-main: #2d3436;
            --text-muted: #636e72;
            --success: #00b894;
            --warning: #f1c40f;
            --shadow: 0 10px 30px rgba(0,0,0,0.08);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        
        /* Prevent horizontal scroll */
        html, body { overflow-x: hidden; width: 100%; }
        body { background: var(--bg-body); color: var(--text-main); display: flex; flex-direction: column; min-height: 100vh; }

        /* ----------------------- 2. MODERN NAVBAR ----------------------- */
        .navbar {
            background: var(--secondary); padding: 12px 6%;
            display: flex; justify-content: space-between; align-items: center;
            position: sticky; top: 0; z-index: 2000; box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        .navbar .brand { font-size: 1.8rem; font-weight: 700; color: var(--primary); text-decoration: none; letter-spacing: 1px; }
        .navbar .brand span { color: #fff; font-weight: 300; }

        .nav-links { display: flex; gap: 10px; align-items: center; }
        .nav-links a {
            color: #fff; text-decoration: none; padding: 10px 18px; border-radius: 10px;
            font-weight: 500; font-size: 0.9rem; transition: 0.3s ease;
        }
        .nav-links a:hover { background: rgba(255, 107, 107, 0.1); color: var(--primary); }
        .nav-btn { background: var(--primary); color: #fff !important; }

        .menu-btn { display: none; cursor: pointer; color: #fff; font-size: 1.6rem; padding: 5px; }

        /* Mobile Menu Overlay */
        .mobile-overlay {
            position: fixed; top: 0; right: -100%; width: 100%; height: 100%;
            background: var(--secondary); z-index: 1500; transition: 0.4s ease;
            display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 25px;
        }
        .mobile-overlay.active { right: 0; }
        .mobile-overlay a { color: #fff; text-decoration: none; font-size: 1.4rem; font-weight: 600; }
        .close-menu { position: absolute; top: 25px; right: 25px; color: #fff; font-size: 2rem; cursor: pointer; }

        /* ----------------------- 3. HERO SECTION ----------------------- */
        .hero {
            background: linear-gradient(rgba(30, 30, 47, 0.8), rgba(30, 30, 47, 0.8)), 
                        url('https://images.unsplash.com/photo-1558981806-ec527fa84c39?auto=format&fit=crop&w=1350&q=80');
            background-size: cover; background-position: center;
            color: #fff; text-align: center; padding: clamp(60px, 10vh, 120px) 20px;
        }
        .hero h1 { font-size: clamp(2rem, 5vw, 3.5rem); font-weight: 800; text-transform: uppercase; margin-bottom: 15px; }
        .hero p { font-size: clamp(0.9rem, 2vw, 1.2rem); max-width: 800px; margin: 0 auto; opacity: 0.9; }

        /* ----------------------- 4. RESPONSIVE GRID ----------------------- */
        .container { width: 90%; max-width: 1200px; margin: auto; padding: 40px 0; flex: 1; }
        .section-header { text-align: center; margin-bottom: 40px; }
        .section-header h2 { font-size: clamp(1.8rem, 4vw, 2.5rem); color: var(--secondary); font-weight: 800; }
        .section-header span { color: var(--primary); }

        /* Grid fixed for narrow screens */
        .bike-grid { 
            display: grid; 
            grid-template-columns: repeat(auto-fit, minmax(min(100%, 290px), 1fr)); 
            gap: 25px; 
        }

        .bike-card {
            background: var(--card-bg); border-radius: 20px; overflow: hidden;
            box-shadow: var(--shadow); transition: 0.4s; display: flex; flex-direction: column;
            border: 1px solid #edf2f7;
        }
        .bike-card:hover { transform: translateY(-8px); }

        .img-wrapper { width: 100%; height: 200px; overflow: hidden; position: relative; }
        .img-wrapper img { width: 100%; height: 100%; object-fit: cover; }
        
        .badge {
            position: absolute; top: 12px; left: 12px; padding: 5px 12px; border-radius: 20px;
            font-size: 0.7rem; font-weight: 700; color: #fff; text-transform: uppercase; z-index: 10;
        }

        .card-content { padding: 20px; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        .card-content h3 { font-size: 1.2rem; color: var(--secondary); margin-bottom: 8px; }
        .card-content .price { font-size: 1.1rem; font-weight: 700; color: var(--primary); margin-bottom: 15px; }

        .btn-book {
            width: 100%; padding: 12px; border-radius: 10px; border: none;
            background: var(--secondary); color: #fff; font-weight: 700; text-decoration: none;
            text-align: center; transition: 0.3s; font-size: 0.9rem;
        }
        .btn-book:hover:not(:disabled) { background: var(--primary); }
        .btn-book:disabled { background: #cbd5e0; cursor: not-allowed; }

        /* ----------------------- 5. UNIVERSAL FOOTER ----------------------- */
        footer { background: var(--secondary); color: #fff; padding: 60px 6% 30px; margin-top: auto; border-top: 5px solid var(--primary); }
        .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 40px; }
        
        .footer-brand h3 { color: var(--primary); font-size: 1.7rem; font-weight: 700; margin-bottom: 15px; }
        .footer-brand p { color: #b2bec3; font-size: 0.9rem; line-height: 1.6; }

        .footer-links h4 { color: #fff; margin-bottom: 20px; font-size: 1.1rem; position: relative; padding-bottom: 8px; }
        .footer-links h4::after { content:''; position: absolute; left: 0; bottom: 0; width: 30px; height: 2px; background: var(--primary); }
        .footer-links ul { list-style: none; }
        .footer-links a { color: #b2bec3; text-decoration: none; display: block; margin-bottom: 10px; font-size: 0.9rem; transition: 0.3s; }
        .footer-links a:hover { color: var(--primary); padding-left: 5px; }

        .footer-contact p { color: #b2bec3; font-size: 0.9rem; margin-bottom: 12px; display: flex; align-items: center; gap: 10px; }
        .footer-contact i { color: var(--primary); }

        .footer-form input, .footer-form textarea {
            width: 100%; padding: 10px; border-radius: 8px; border: none; background: #2d2d44; color: #fff; margin-bottom: 8px; outline: none;
        }
        .footer-form button {
            width: 100%; padding: 10px; background: var(--primary); color: #fff; border: none; border-radius: 8px; font-weight: 700; cursor: pointer;
        }

        .copyright { text-align: center; padding-top: 30px; margin-top: 40px; border-top: 1px solid #2d2d44; color: #636e72; font-size: 0.8rem; }

        /* ----------------------- 6. RESPONSIVE QUERIES ----------------------- */
        @media (max-width: 850px) {
            .nav-links { display: none; }
            .menu-btn { display: block; }
        }

        @media (max-width: 480px) {
            .navbar { padding: 12px 5%; }
            .container { width: 95%; }
            .hero { padding: 50px 15px; }
        }
    </style>
</head>
<body>

    <header class="navbar">
        <a href="/" class="brand">Bike<span>Rental</span></a>
        <div class="menu-btn" onclick="toggleMenu()"><i class="fas fa-bars"></i></div>
        <nav class="nav-links">
            <a href="/">Home</a>
            <% if (!user) { %>
                <a href="/login">Login</a>
                <a href="/signup" class="nav-btn">Signup</a>
            <% } else { %>
                <a href="<%= user.role === 'admin' ? '/admin/dashboard' : '/user/dashboard' %>">Dashboard</a>
                <a href="/logout" class="nav-btn">Logout</a>
            <% } %>
        </nav>
    </header>

    <div class="mobile-overlay" id="mobileNav">
        <div class="close-menu" onclick="toggleMenu()"><i class="fas fa-times"></i></div>
        <a href="/" onclick="toggleMenu()">Home</a>
        <% if (!user) { %>
            <a href="/login" onclick="toggleMenu()">Login</a>
            <a href="/signup" onclick="toggleMenu()">Signup</a>
        <% } else { %>
            <a href="<%= user.role === 'admin' ? '/admin/dashboard' : '/user/dashboard' %>" onclick="toggleMenu()">Dashboard</a>
            <a href="/logout" onclick="toggleMenu()">Logout</a>
        <% } %>
    </div>

    <section class="hero">
        <div class="container">
            <h1>Premium Rides, Simplified.</h1>
            <p>Don't just commute, enjoy the ride. Book top-quality bikes at the most affordable rates in town.</p>
        </div>
    </section>

    <main class="container">
        <div class="section-header">
            <h2>Explore Our <span>Fleet</span></h2>
        </div>
        
        <div class="bike-grid">
            <% if (!bikes || bikes.length === 0) { %>
                <div style="grid-column: 1/-1; text-align: center; padding: 40px;">
                    <i class="fas fa-motorcycle fa-3x" style="color: #cbd5e0; margin-bottom: 15px;"></i>
                    <p style="color: var(--text-muted);">No rides available right now.</p>
                </div>
            <% } else { %>
                <% bikes.forEach(b => { %>
                    <div class="bike-card">
                        <div class="img-wrapper">
                            <% if (!b.isAvailable) { %>
                                <span class="badge" style="background: var(--text-muted);">Service</span>
                            <% } else if (b.isCurrentlyRented) { %>
                                <span class="badge" style="background: var(--warning); color: #000;">Booked</span>
                            <% } else { %>
                                <span class="badge" style="background: var(--success);">Available</span>
                            <% } %>
                            <img src="<%= b.image || 'https://via.placeholder.com/400x250?text=No+Image' %>" alt="<%= b.name %>">
                        </div>

                        <div class="card-content">
                            <div>
                                <h3><%= b.name %></h3>
                                <p class="price">₹ <%= b.pricePerDay %> <small style="font-weight: 400; color: var(--text-muted);">/ Day</small></p>
                            </div>

                            <% if (!b.isAvailable || b.isCurrentlyRented) { %>
                                <button class="btn-book" disabled>Not Available</button>
                            <% } else { %>
                                <a class="btn-book" href="/bike/<%= b._id %>">View Details</a>
                            <% } %>
                        </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </main>

    <footer>
        <div class="footer-grid">
            <div class="footer-brand">
                <h3>BikeRental</h3>
                <p>Your premium partner for city commutes. We provide safe, sanitized, and high-performance bikes for all your travel needs.</p>
                <div style="display: flex; gap: 15px; margin-top: 20px;">
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-x-twitter"></i></a>
                </div>
            </div>

            <div class="footer-links">
                <h4>Navigation</h4>
                <ul>
                    <li><a href="/">All Bikes</a></li>
                    <li><a href="/user/dashboard">My Bookings</a></li>
                    <li><a href="/login">Login Area</a></li>
                </ul>
            </div>

            <div class="footer-contact">
                <h4>Contact Info</h4>
                <p><i class="fas fa-envelope"></i> support@bikerental.com</p>
                <p><i class="fas fa-phone"></i> +91 98765 43210</p>
                <p><i class="fas fa-location-dot"></i> Civil Lines, Jabalpur</p>
            </div>

            <div class="footer-form">
                <h4>Feedback</h4>
                <form action="/feedback" method="POST">
                    <input type="text" placeholder="Your Name" required>
                    <textarea placeholder="Message..." rows="2" required></textarea>
                    <button type="submit">Submit</button>
                </form>
            </div>
        </div>

        <div class="copyright">
            <p>© <%= new Date().getFullYear() %> BikeRental System | Premium Mobility Solution | Developed by Aniket Kumar Gupta</p>
        </div>
    </footer>

    <script>
        function toggleMenu() {
            document.getElementById("mobileNav").classList.toggle("active");
        }
    </script>
</body>
</html>