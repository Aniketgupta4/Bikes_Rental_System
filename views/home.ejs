<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>BikeRental - Ride Your Way</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        /* ----------------------- 1. DESIGN SYSTEM ----------------------- */
        :root {
            --primary: #ff6b6b;
            --primary-dark: #ee5253;
            --secondary: #1e1e2f;
            --bg-body: #f4f7fe;
            --card-bg: #ffffff;
            --text-main: #2d3436;
            --text-muted: #636e72;
            --success: #00b894;
            --danger: #d63031;
            --shadow: 0 10px 30px rgba(0,0,0,0.08);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        html, body { overflow-x: hidden; width: 100%; }
        body { background: var(--bg-body); color: var(--text-main); display: flex; flex-direction: column; min-height: 100vh; }

        /* ----------------------- 2. MODERN NAVBAR ----------------------- */
        .navbar {
            background: var(--secondary); padding: 15px 6%;
            display: flex; justify-content: space-between; align-items: center;
            position: sticky; top: 0; z-index: 2000; box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        .navbar .brand { font-size: 1.8rem; font-weight: 700; color: var(--primary); text-decoration: none; letter-spacing: 1px; }
        .navbar .brand span { color: #fff; font-weight: 300; }

        .nav-links { display: flex; gap: 15px; align-items: center; }
        .nav-links a { color: #fff; text-decoration: none; padding: 10px 18px; border-radius: 10px; font-weight: 500; font-size: 0.95rem; transition: 0.3s ease; }
        .nav-links a:hover { background: rgba(255, 107, 107, 0.1); color: var(--primary); }
        .nav-btn { background: var(--primary); color: #fff !important; }
        .nav-btn:hover { background: var(--primary-dark) !important; color: #fff !important; }

        .menu-btn { display: none; cursor: pointer; color: #fff; font-size: 1.6rem; padding: 5px; }

        /* Mobile Menu Overlay */
        .mobile-overlay {
            position: fixed; top: 0; right: -100%; width: 100%; height: 100%;
            background: var(--secondary); z-index: 2500; transition: 0.4s ease;
            display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 25px;
        }
        .mobile-overlay.active { right: 0; }
        .mobile-overlay a { color: #fff; text-decoration: none; font-size: 1.5rem; font-weight: 600; }
        .close-menu { position: absolute; top: 25px; right: 25px; color: #fff; font-size: 2.2rem; cursor: pointer; }

        /* ----------------------- 3. HERO SECTION ----------------------- */
        .hero {
            background: linear-gradient(rgba(30, 30, 47, 0.75), rgba(30, 30, 47, 0.85)), 
                        url('https://images.unsplash.com/photo-1558981806-ec527fa84c39?auto=format&fit=crop&w=1350&q=80');
            background-size: cover; background-position: center;
            color: #fff; text-align: center; padding: clamp(80px, 12vh, 150px) 20px;
        }
        .hero h1 { font-size: clamp(2.2rem, 5vw, 4rem); font-weight: 800; text-transform: uppercase; margin-bottom: 15px; letter-spacing: 1px; }
        .hero p { font-size: clamp(1rem, 2vw, 1.2rem); max-width: 800px; margin: 0 auto; opacity: 0.9; line-height: 1.6; }

        /* ----------------------- 4. RESPONSIVE GRID & CARDS ----------------------- */
        .container { width: 90%; max-width: 1250px; margin: auto; padding: 60px 0; flex: 1; }
        .section-header { text-align: center; margin-bottom: 50px; }
        .section-header h2 { font-size: clamp(2rem, 4vw, 2.8rem); color: var(--secondary); font-weight: 800; }
        .section-header span { color: var(--primary); }

        .bike-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; }

        .bike-card {
            background: var(--card-bg); border-radius: 20px; overflow: hidden;
            box-shadow: var(--shadow); transition: transform 0.3s ease, box-shadow 0.3s ease; 
            display: flex; flex-direction: column; border: 1px solid #edf2f7;
        }
        .bike-card:hover { transform: translateY(-8px); box-shadow: 0 15px 40px rgba(0,0,0,0.12); }

        .img-wrapper { width: 100%; height: 220px; overflow: hidden; position: relative; }
        .img-wrapper img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
        .bike-card:hover .img-wrapper img { transform: scale(1.05); }
        
        .badge {
            position: absolute; top: 15px; left: 15px; padding: 6px 14px; border-radius: 25px;
            font-size: 0.75rem; font-weight: 700; color: #fff; text-transform: uppercase; z-index: 10;
            display: flex; align-items: center; gap: 6px; box-shadow: 0 4px 10px rgba(0,0,0,0.2);
        }
        .badge-available { background: var(--success); }
        .badge-booked { background: var(--danger); }
        .badge-maintenance { background: #718096; } /* NEW: Grey color for maintenance */

        .card-content { padding: 25px; flex-grow: 1; display: flex; flex-direction: column; justify-content: space-between; }
        .card-content h3 { font-size: 1.4rem; font-weight: 700; color: var(--secondary); margin-bottom: 8px; }
        .card-content .price { font-size: 1.2rem; font-weight: 700; color: var(--primary); margin-bottom: 20px; }

        .btn-book {
            width: 100%; padding: 14px; border-radius: 12px; border: none;
            background: var(--secondary); color: #fff; font-weight: 700; text-decoration: none;
            text-align: center; transition: 0.3s; font-size: 1rem; display: block;
        }
        .btn-book:hover:not(.disabled) { background: var(--primary); transform: translateY(-2px); }
        .btn-book.disabled { background: #cbd5e0; color: #718096; cursor: not-allowed; pointer-events: none; }
        
        /* Specific disabled styling for maintenance */
        .btn-book.maintenance-btn { background: #e2e8f0; color: #4a5568; }

        /* ----------------------- 5. UNIVERSAL FOOTER ----------------------- */
        footer { background: var(--secondary); color: #fff; padding: 80px 6% 40px; margin-top: auto; border-top: 6px solid var(--primary); }
        .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 50px; max-width: 1250px; margin: 0 auto; }
        
        .footer-brand h3 { color: var(--primary); font-size: 2rem; font-weight: 800; margin-bottom: 20px; }
        .footer-brand p { color: #b2bec3; font-size: 0.95rem; line-height: 1.8; }
        .social-icons { display: flex; gap: 15px; margin-top: 20px; }
        .social-icons a { color: var(--primary); font-size: 1.3rem; transition: 0.3s; }
        .social-icons a:hover { color: #fff; }

        .footer-links h4 { color: #fff; margin-bottom: 25px; font-size: 1.2rem; }
        .footer-links ul { list-style: none; }
        .footer-links a { color: #b2bec3; text-decoration: none; display: block; margin-bottom: 12px; font-size: 0.95rem; transition: 0.3s; }
        .footer-links a:hover { color: var(--primary); padding-left: 8px; }

        .footer-contact p { color: #b2bec3; font-size: 0.95rem; margin-bottom: 15px; display: flex; align-items: center; gap: 12px; }
        .footer-contact i { color: var(--primary); width: 20px; }

        .footer-form input, .footer-form textarea { width: 100%; padding: 12px; border-radius: 10px; border: none; background: #2d2d44; color: #fff; margin-bottom: 12px; outline: none; font-family: inherit; }
        .footer-form button { width: 100%; padding: 12px; background: var(--primary); color: #fff; border: none; border-radius: 10px; font-weight: 700; cursor: pointer; transition: 0.3s; }
        .footer-form button:hover { background: var(--primary-dark); }

        .copyright { text-align: center; padding-top: 40px; margin-top: 60px; border-top: 1px solid #2d2d44; color: #636e72; font-size: 0.85rem; }

        /* ----------------------- 6. RESPONSIVE QUERIES ----------------------- */
        @media (max-width: 900px) { .nav-links { display: none; } .menu-btn { display: block; } }
        @media (max-width: 600px) {
            .navbar { padding: 15px 5%; }
            .container { padding: 40px 0; }
            .hero { padding: 60px 20px; }
            .bike-grid { grid-template-columns: 1fr; padding: 0 10px; }
        }

        /* ----------------------- 7. CHATBOT CSS ----------------------- */
        #chat-fab {
            position: fixed; bottom: 30px; right: 30px; z-index: 5000;
            width: 60px; height: 60px; border-radius: 50%;
            background: var(--primary); color: #fff;
            border: none; font-size: 1.6rem; cursor: pointer;
            box-shadow: 0 5px 20px rgba(255,107,107,0.4); transition: transform 0.3s ease, background 0.3s;
            display: flex; align-items: center; justify-content: center;
        }
        #chat-fab:hover { transform: scale(1.1); background: var(--primary-dark); }

        #chat-window {
            position: fixed; bottom: 100px; right: 30px; z-index: 5000;
            width: 360px; height: 480px; max-width: calc(100% - 40px); max-height: 70vh;
            background: #fff; border-radius: 16px; box-shadow: 0 10px 40px rgba(0,0,0,0.15);
            display: none; flex-direction: column; overflow: hidden; border: 1px solid #edf2f7;
        }
        #chat-window.open { display: flex; animation: slideUpChat 0.4s cubic-bezier(0.165, 0.84, 0.44, 1); }
        @keyframes slideUpChat { from { opacity: 0; transform: translateY(20px) scale(0.95); } to { opacity: 1; transform: translateY(0) scale(1); } }

        .chat-header { background: var(--secondary); color: #fff; padding: 16px 20px; display: flex; justify-content: space-between; align-items: center; }
        .chat-header h3 { margin: 0; font-size: 1.05rem; font-weight: 600; }
        .chat-close { background: none; border: none; color: rgba(255,255,255,0.7); font-size: 1.8rem; cursor: pointer; line-height: 1; transition: 0.2s; }
        .chat-close:hover { color: #fff; transform: scale(1.1); }
        
        .chat-body { flex: 1; padding: 18px; overflow-y: auto; background: #f9f9ff; display: flex; flex-direction: column; gap: 12px; }
        .chat-msg { padding: 12px 16px; border-radius: 14px; max-width: 85%; font-size: 0.9rem; line-height: 1.5; }
        .msg-bot { background: #fff; border: 1px solid #edf2f7; align-self: flex-start; border-bottom-left-radius: 4px; color: #2d3436; box-shadow: 0 2px 5px rgba(0,0,0,0.02); }
        .msg-user { background: var(--primary); color: #fff; align-self: flex-end; border-bottom-right-radius: 4px; }
        
        .chat-input-container { display: flex; padding: 15px; background: #fff; border-top: 1px solid #edf2f7; align-items: center;}
        .chat-input-container input { flex: 1; padding: 12px 15px; border: 1px solid #edf2f7; border-radius: 10px; outline: none; font-size: 0.9rem; font-family: inherit; transition: 0.3s; }
        .chat-input-container input:focus { border-color: var(--primary); box-shadow: 0 0 0 2px rgba(255,107,107,0.1); }
        .chat-input-container button { background: none; border: none; color: var(--primary); font-size: 1.4rem; cursor: pointer; margin-left: 12px; transition: 0.3s; }
        .chat-input-container button:hover { transform: scale(1.1); color: var(--primary-dark); }
        
        @media (max-width: 480px) {
            #chat-window { right: 20px; bottom: 90px; width: calc(100% - 40px); }
            #chat-fab { right: 20px; bottom: 20px; }
        }
    </style>
</head>
<body>

    <header class="navbar">
        <a href="/" class="brand">Bike<span>Rental</span></a>
        <div class="menu-btn" onclick="toggleMenu()"><i class="fas fa-bars"></i></div>
        <nav class="nav-links">
            <% if (!user) { %>
                <a href="/login">Login</a>
                <a href="/signup" class="nav-btn">Signup</a>
            <% } else { %>
                <a href="<%= user.role === 'admin' ? '/admin/dashboard' : '/user/dashboard' %>">Dashboard</a>
                <a href="/logout" class="nav-btn">Logout</a>
            <% } %>
        </nav>
    </header>

    <div class="mobile-overlay" id="mobileNav">
        <div class="close-menu" onclick="toggleMenu()"><i class="fas fa-times"></i></div>
        <a href="/" onclick="toggleMenu()">Home</a>
        <% if (!user) { %>
            <a href="/login" onclick="toggleMenu()">Login</a>
            <a href="/signup" onclick="toggleMenu()">Signup</a>
        <% } else { %>
            <a href="<%= user.role === 'admin' ? '/admin/dashboard' : '/user/dashboard' %>" onclick="toggleMenu()">Dashboard</a>
            <a href="/logout" onclick="toggleMenu()">Logout</a>
        <% } %>
    </div>

    <section class="hero">
        <div class="container" style="padding: 0;">
            <h1>Premium Rides, Simplified.</h1>
            <p>Don't just commute, enjoy the ride. Book top-quality bikes at the most affordable rates in town.</p>
        </div>
    </section>

    <main class="container">
        <div class="section-header">
            <h2>Explore Our <span>Fleet</span></h2>
        </div>
        
        <div class="bike-grid">
            <% if (!bikes || bikes.length === 0) { %>
                <div style="grid-column: 1/-1; text-align: center; padding: 50px;">
                    <i class="fas fa-motorcycle fa-4x" style="color: #cbd5e0; margin-bottom: 20px;"></i>
                    <p style="color: var(--text-muted); font-size: 1.2rem;">No rides available right now.</p>
                </div>
            <% } else { %>
                <% bikes.forEach(b => { %>
                    <div class="bike-card">
                        <div class="img-wrapper">
                            
                            <% if (b.isMaintenance) { %>
                                <span class="badge badge-maintenance"><i class="fas fa-tools"></i> In Service</span>
                            <% } else if (b.isAvailable) { %>
                                <span class="badge badge-available"><i class="fas fa-check-circle"></i> Available</span>
                            <% } else { %>
                                <span class="badge badge-booked"><i class="fas fa-lock"></i> Currently Booked</span>
                            <% } %>
                            <img src="<%= b.image ? b.image : 'https://via.placeholder.com/400x250?text=No+Image' %>" alt="<%= b.name %>">
                        </div>

                        <div class="card-content">
                            <div>
                                <h3><%= b.name %></h3>
                                <p class="price">₹ <%= b.pricePerDay %> <small style="font-weight: 400; color: var(--text-muted);">/ Day</small></p>
                            </div>

                            <% if (b.isMaintenance) { %>
                                <button class="btn-book disabled maintenance-btn" disabled><i class="fas fa-wrench"></i> Under Maintenance</button>
                            <% } else if (b.isAvailable) { %>
                                <a class="btn-book" href="/bike/<%= b._id %>">Rent Now</a>
                            <% } else { %>
                                <button class="btn-book disabled" disabled>Unavailable</button>
                            <% } %>
                            </div>
                    </div>
                <% }) %>
            <% } %>
        </div>
    </main>

    <footer>
        <div class="footer-grid">
            <div class="footer-brand">
                <h3>BikeRental</h3>
                <p>Your premium partner for city commutes. We provide safe, sanitized, and high-performance bikes for all your travel needs.</p>
                <div class="social-icons">
                    <a href="#"><i class="fab fa-facebook-f"></i></a>
                    <a href="#"><i class="fab fa-instagram"></i></a>
                    <a href="#"><i class="fab fa-linkedin-in"></i></a>
                </div>
            </div>
            <div class="footer-links">
                <h4>Navigation</h4>
                <ul>
                    <li><a href="/">Browse Fleet</a></li>
                    <li><a href="/login">User Login</a></li>
                    <li><a href="/signup">Create Account</a></li>
                </ul>
            </div>
            <div class="footer-contact">
                <h4>Contact Info</h4>
                <p><i class="fas fa-envelope"></i> support@bikerental.com</p>
                <p><i class="fas fa-phone"></i> +91 98765 43210</p>
                <p><i class="fas fa-location-dot"></i> Civil Lines, Jabalpur</p>
            </div>
            <div class="footer-links">
                <h4>Quick Feedback</h4>
                <form action="/feedback" method="POST" class="footer-form">
                    <input type="text" placeholder="Your Name" required>
                    <textarea placeholder="Message..." rows="2" required></textarea>
                    <button type="submit">Submit Note</button>
                </form>
            </div>
        </div>
        <div class="copyright">
            <p>© <%= new Date().getFullYear() %> BikeRental System | Premium Mobility Solution | Developed by Aniket Kumar Gupta</p>
        </div>
    </footer>

    <button id="chat-fab"><i class="fas fa-comment-dots"></i></button>

    <div id="chat-window">
        <div class="chat-header">
            <h3><i class="fas fa-motorcycle"></i> Bike Assistant</h3>
            <button class="chat-close" id="chat-close">&times;</button>
        </div>
        
        <div class="chat-body" id="chat-body">
            <div class="chat-msg msg-bot">
                <% if (user) { %>
                    Hi <%= user.name %>! I am your Bike Assistant. How can I help you today?
                <% } else { %>
                    Hi there! 👋 I am the AI Bike Assistant. Please <b>Login</b> to ask me anything about our bikes, mileage, or rentals!
                <% } %>
            </div>
        </div>
        
        <div class="chat-input-container">
            <% if (user) { %>
                <input type="text" id="chat-input" placeholder="Type your bike query...">
                <button id="chat-send"><i class="fas fa-paper-plane"></i></button>
            <% } else { %>
                <input type="text" disabled placeholder="Login required to chat..." style="background: #f1f5f9; cursor: not-allowed;">
                <a href="/login" style="margin-left: 12px; color: var(--primary); font-weight: 700; text-decoration: none;">Login</a>
            <% } %>
        </div>
    </div>

    <script>
        // Navbar Mobile Menu Toggle
        function toggleMenu() { 
            document.getElementById("mobileNav").classList.toggle("active"); 
        }

        // Chatbot UI Toggle
        const chatFab = document.getElementById('chat-fab');
        const chatWindow = document.getElementById('chat-window');
        const chatClose = document.getElementById('chat-close');
        
        chatFab.onclick = () => {
            chatWindow.classList.toggle('open');
            const input = document.getElementById('chat-input');
            if (chatWindow.classList.contains('open') && input && !input.disabled) {
                input.focus();
            }
        };
        chatClose.onclick = () => chatWindow.classList.remove('open');

        // Chatbot Messaging Logic (Runs ONLY if user is passed from backend)
        const isLoggedIn = <%= user ? 'true' : 'false' %>;

        if (isLoggedIn) {
            const chatInput = document.getElementById('chat-input');
            const chatSend = document.getElementById('chat-send');
            const chatBody = document.getElementById('chat-body');

            async function sendMessage() {
                const text = chatInput.value.trim();
                if (!text) return;

                appendMessage(text, 'msg-user');
                chatInput.value = '';
                chatInput.disabled = true;

                const loadingId = appendMessage('<i class="fas fa-circle-notch fa-spin"></i> Typing...', 'msg-bot');

                try {
                    const response = await fetch('/api/chat', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ message: text })
                    });
                    
                    const data = await response.json();
                    
                    document.getElementById(loadingId).remove();
                    appendMessage(data.reply, 'msg-bot');
                } catch (err) {
                    console.error("Chatbot Error:", err);
                    document.getElementById(loadingId).remove();
                    appendMessage('⚠️ I am currently offline. Please try again later.', 'msg-bot');
                } finally {
                    chatInput.disabled = false;
                    chatInput.focus();
                }
            }

            if (chatSend) {
                chatSend.onclick = sendMessage;
            }
            if (chatInput) {
                chatInput.onkeypress = (e) => { if (e.key === 'Enter') sendMessage(); };
            }

            function appendMessage(text, className) {
                const div = document.createElement('div');
                div.className = `chat-msg ${className}`;
                div.id = 'msg-' + Date.now();
                div.innerHTML = text.replace(/\*\*(.*?)\*\*/g, '<b>$1</b>');
                chatBody.appendChild(div);
                chatBody.scrollTop = chatBody.scrollHeight;
                return div.id;
            }
        }
    </script>
</body>
</html>