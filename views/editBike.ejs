<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Vehicle - Admin Portal</title>
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        /* ----------------------- 1. DESIGN SYSTEM ----------------------- */
        :root {
            --primary: #ff6b6b;
            --primary-dark: #ee5253;
            --secondary: #1e1e2f;
            --bg-body: #f4f7fe;
            --card-bg: #ffffff;
            --text-main: #2d3436;
            --text-muted: #636e72;
            --danger: #d63031;
            --shadow: 0 10px 30px rgba(0,0,0,0.08);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        html, body { overflow-x: hidden; width: 100%; min-height: 100vh; }
        body { background: var(--bg-body); color: var(--text-main); display: flex; flex-direction: column; }

        /* ----------------------- 2. UNIVERSAL NAVBAR ----------------------- */
        .navbar {
            background: var(--secondary); padding: 12px 6%;
            display: flex; justify-content: space-between; align-items: center;
            position: sticky; top: 0; z-index: 2000; box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        .navbar .brand { font-size: 1.8rem; font-weight: 700; color: var(--primary); text-decoration: none; letter-spacing: 1px; }
        .navbar .brand span { color: #fff; font-weight: 300; }

        .nav-links { display: flex; gap: 10px; align-items: center; }
        .nav-links a {
            color: #fff; text-decoration: none; padding: 10px 18px; border-radius: 10px;
            font-weight: 500; font-size: 0.9rem; transition: 0.3s ease;
        }
        .nav-links a:hover { background: rgba(255, 107, 107, 0.1); color: var(--primary); }
        .logout-btn { background: var(--primary); color: #fff !important; }

        .menu-btn { display: none; cursor: pointer; color: #fff; font-size: 1.6rem; padding: 5px; }

        /* Mobile Menu Overlay */
        .mobile-overlay {
            position: fixed; top: 0; right: -100%; width: 100%; height: 100%;
            background: var(--secondary); z-index: 2500; transition: 0.4s ease;
            display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 25px;
        }
        .mobile-overlay.active { right: 0; }
        .mobile-overlay a { color: #fff; text-decoration: none; font-size: 1.5rem; font-weight: 600; }
        .close-menu { position: absolute; top: 25px; right: 25px; color: #fff; font-size: 2.2rem; cursor: pointer; }

        /* ----------------------- 3. FORM CARD LAYOUT ----------------------- */
        main.container {
            width: 90%; max-width: 650px; margin: 40px auto; flex: 1;
            animation: fadeIn 0.8s ease;
        }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        .btn-back {
            display: inline-flex; align-items: center; gap: 8px; color: var(--secondary);
            text-decoration: none; font-weight: 600; margin-bottom: 25px; transition: 0.3s;
        }
        .btn-back:hover { color: var(--primary); transform: translateX(-5px); }

        .form-card {
            background: var(--card-bg); padding: 45px; border-radius: 30px;
            box-shadow: var(--shadow); border: 1px solid #edf2f7;
        }
        .form-card h2 { font-size: 2rem; font-weight: 800; color: var(--secondary); margin-bottom: 30px; }

        /* Form Grouping */
        .form-group { margin-bottom: 22px; text-align: left; }
        .form-group label { display: block; font-size: 0.85rem; font-weight: 700; color: var(--secondary); margin-bottom: 8px; text-transform: uppercase; }
        
        input:not([type="checkbox"]), textarea {
            width: 100%; padding: 14px; border-radius: 12px; border: 2.5px solid #e2e8f0;
            font-size: 1rem; outline: none; transition: 0.3s; background: #fff;
        }
        input:focus, textarea:focus { border-color: var(--primary); box-shadow: 0 0 0 5px rgba(255, 107, 107, 0.1); }

        /* Custom Switch Label */
        .switch-container {
            display: flex; align-items: center; gap: 12px; padding: 18px;
            background: #f8fafc; border-radius: 15px; cursor: pointer; border: 2px solid #edf2f7; margin: 25px 0;
            transition: 0.3s;
        }
        .switch-container:hover { border-color: var(--primary); }
        .switch-container input[type="checkbox"] { width: 22px; height: 22px; accent-color: var(--primary); cursor: pointer; }
        .switch-container label { font-weight: 700; color: var(--secondary); margin: 0; cursor: pointer; flex: 1; font-size: 1.05rem;}
        .switch-container p { font-size: 0.8rem; color: var(--text-muted); margin-top: 5px; font-weight: 400; line-height: 1.4;}

        /* Image Preview Section */
        .upload-area { margin-top: 30px; }
        .preview-box {
            width: 100%; height: 240px; background: #f1f5f9; border: 2.5px dashed #cbd5e0;
            border-radius: 20px; display: flex; align-items: center; justify-content: center;
            overflow: hidden; margin-bottom: 15px; position: relative;
        }
        .preview-box img { width: 100%; height: 100%; object-fit: cover; }
        .preview-box p { color: var(--text-muted); font-size: 0.9rem; }

        .file-input-wrapper { position: relative; overflow: hidden; display: block; width: 100%; }
        .file-input-wrapper input[type=file] { position: absolute; left: 0; top: 0; opacity: 0; width: 100%; height: 100%; cursor: pointer; }
        .custom-upload-btn {
            display: block; width: 100%; padding: 14px; background: var(--secondary); color: #fff;
            text-align: center; border-radius: 12px; font-weight: 600; cursor: pointer; transition: 0.3s;
        }
        .custom-upload-btn:hover { background: #000; }

        .btn-submit {
            width: 100%; padding: 16px; border-radius: 15px; border: none;
            background: var(--primary); color: #fff; font-size: 1.1rem; font-weight: 700;
            cursor: pointer; transition: 0.3s; margin-top: 25px; text-transform: uppercase;
            box-shadow: 0 10px 20px rgba(255, 107, 107, 0.2);
        }
        .btn-submit:hover { background: var(--primary-dark); transform: translateY(-3px); }


        /* ----------------------- 5. RESPONSIVE QUERIES ----------------------- */
        @media (max-width: 850px) {
            .nav-links { display: none; }
            .menu-btn { display: block; }
        }
        @media (max-width: 480px) {
            .form-card { padding: 35px 25px; border-radius: 20px; }
            .form-card h2 { font-size: 1.7rem; }
            .navbar { padding: 12px 5%; }
        }
    </style>
</head>
<body>

    <header class="navbar">
        <a href="/" class="brand">Bike<span> Rental</span></a>
        <div class="menu-btn" onclick="toggleMenu()"><i class="fas fa-bars"></i></div>
        <nav class="nav-links">
            <a href="/admin/dashboard">Control Panel</a>
            <a href="/">Live Site</a>
            <a href="/logout" class="logout-btn">Admin Logout</a>
        </nav>
    </header>

    <div class="mobile-overlay" id="mobileNav">
        <div class="close-menu" onclick="toggleMenu()"><i class="fas fa-times"></i></div>
        <a href="/admin/dashboard" onclick="toggleMenu()">Dashboard</a>
        <a href="/" onclick="toggleMenu()">Live Site</a>
        <a href="/logout" onclick="toggleMenu()">Logout</a>
    </div>

    <main class="container">
        <a href="/admin/dashboard" class="btn-back"><i class="fas fa-arrow-left"></i> Return to Inventory</a>

        <div class="form-card">
            <h2>Edit Vehicle Config</h2>

            <form action="/admin/edit-bike/<%= bike._id %>" method="POST" enctype="multipart/form-data">
                
                <div class="form-group">
                    <label>Vehicle Name / Model</label>
                    <input type="text" name="name" value="<%= bike.name %>" required placeholder="e.g. Yamaha R15 v4">
                </div>

                <div class="form-group">
                    <label>Daily Rental Rate (₹)</label>
                    <input type="number" name="pricePerDay" value="<%= bike.pricePerDay %>" required min="1">
                </div>

                <div class="form-group">
                    <label>Detailed Specifications</label>
                    <textarea name="description" rows="4" required placeholder="Engine, Mileage, Top Speed..."><%= bike.description %></textarea>
                </div>

                <% if (bike.isAvailable === false && bike.isMaintenance === false) { %>
                    <div style="background: #fff5f5; border: 1px solid #fed7d7; padding: 15px; border-radius: 12px; margin: 20px 0; color: var(--danger); font-weight: 500; font-size: 0.9rem;">
                        <i class="fas fa-lock" style="margin-right: 8px;"></i> This bike is currently out on rent (Booked). Checkbox logic will not disturb the booking.
                    </div>
                <% } %>

                <div class="switch-container">
                    <input type="checkbox" id="isAvailable" name="isAvailable" <%= bike.isAvailable ? 'checked' : '' %>> 
                    <label for="isAvailable">
                        Available for Rent
                        <p>Keep ticked to show available. <b>Untick to show "In Service" (Maintenance).</b></p>
                    </label>
                </div>

                <div class="upload-area">
                    <label>Update Presentation Image</label>
                    <div class="preview-box" id="previewContainer">
                        <% if (bike.image) { %>
                            <img src="<%= bike.image %>" id="previewImg" alt="Bike Image">
                        <% } else { %>
                            <p id="previewText">No image assigned yet</p>
                            <img src="" id="previewImg" style="display: none;">
                        <% } %>
                    </div>
                    
                    <div class="file-input-wrapper">
                        <span class="custom-upload-btn"><i class="fas fa-camera"></i> Change Vehicle Image</span>
                        <input type="file" name="image" id="imageInput" accept="image/*">
                    </div>
                </div>

                <button type="submit" class="btn-submit">Commit Changes</button>
            </form>
        </div>
    </main>

    <%- include('partials/footer') %>

    <script>
        // 1. Navbar Toggle
        function toggleMenu() {
            document.getElementById("mobileNav").classList.toggle("active");
        }

        // 2. Pro Live Preview Logic
        const imageInput = document.getElementById('imageInput');
        const previewImg = document.getElementById('previewImg');
        const previewText = document.getElementById('previewText');

        imageInput.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    previewImg.src = e.target.result;
                    previewImg.style.display = 'block';
                    if (previewText) previewText.style.display = 'none';
                }
                reader.readAsDataURL(file);
            }
        });
    </script>

</body>
</html>