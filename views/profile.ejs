<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Profile - BikeRental</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <style>
        /* ----------------------- 1. DESIGN SYSTEM ----------------------- */
        :root {
            --primary: #ff6b6b;
            --primary-dark: #ee5253;
            --secondary: #1e1e2f;
            --bg-body: #f4f7fe;
            --card-bg: #ffffff;
            --text-main: #2d3436;
            --text-muted: #636e72;
            --success: #00b894;
            --shadow: 0 15px 35px rgba(0,0,0,0.1);
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        html, body { overflow-x: hidden; width: 100%; min-height: 100vh; }
        body { background: var(--bg-body); color: var(--text-main); display: flex; flex-direction: column; }

        /* ----------------------- 2. UNIVERSAL NAVBAR ----------------------- */
        .navbar {
            background: var(--secondary); padding: 12px 6%;
            display: flex; justify-content: space-between; align-items: center;
            position: sticky; top: 0; z-index: 2000; box-shadow: 0 4px 15px rgba(0,0,0,0.2);
        }
        .navbar .brand { font-size: 1.8rem; font-weight: 700; color: var(--primary); text-decoration: none; letter-spacing: 1px; }
        .navbar .brand span { color: #fff; font-weight: 300; }

        .nav-links { display: flex; gap: 10px; align-items: center; }
        .nav-links a {
            color: #fff; text-decoration: none; padding: 10px 18px; border-radius: 10px;
            font-weight: 500; font-size: 0.9rem; transition: 0.3s ease;
        }
        .nav-links a:hover, .nav-links a.active { background: rgba(255, 107, 107, 0.1); color: var(--primary); }
        .logout-link { background: var(--primary) !important; color: #fff !important; }

        .menu-btn { display: none; cursor: pointer; color: #fff; font-size: 1.6rem; padding: 5px; }

        /* Mobile Overlay */
        .mobile-overlay {
            position: fixed; top: 0; right: -100%; width: 100%; height: 100%;
            background: var(--secondary); z-index: 2500; transition: 0.4s ease;
            display: flex; flex-direction: column; align-items: center; justify-content: center; gap: 25px;
        }
        .mobile-overlay.active { right: 0; }
        .mobile-overlay a { color: #fff; text-decoration: none; font-size: 1.5rem; font-weight: 600; }
        .close-menu { position: absolute; top: 25px; right: 25px; color: #fff; font-size: 2.2rem; cursor: pointer; }

        /* ----------------------- 3. PROFILE CONTENT ----------------------- */
        main.container {
            flex: 1; display: flex; flex-direction: column; align-items: center;
            padding: 60px 20px; animation: fadeInUp 0.8s ease;
        }

        @keyframes fadeInUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }

        .profile-header { text-align: center; margin-bottom: 40px; }
        .profile-header h2 { font-size: 2.2rem; font-weight: 800; color: var(--secondary); }
        .profile-header p { color: var(--text-muted); font-size: 1rem; }

        .profile-card {
            background: var(--card-bg); width: 100%; max-width: 550px;
            padding: 50px 40px; border-radius: 30px; box-shadow: var(--shadow);
            text-align: center; border: 1px solid #edf2f7; position: relative;
            overflow: hidden;
        }
        .profile-card::before {
            content: ''; position: absolute; top: 0; left: 0; width: 100%; height: 6px;
            background: var(--primary);
        }

        .avatar-section {
            width: 110px; height: 110px; background: #f8fafc; color: var(--primary);
            border-radius: 50%; display: flex; align-items: center; justify-content: center;
            font-size: 3rem; margin: 0 auto 30px; border: 3px solid #f1f5f9;
            box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        }

        .info-group { margin-bottom: 15px; }
        .info-row {
            display: flex; justify-content: space-between; align-items: center;
            padding: 18px 0; border-bottom: 1px solid #f1f5f9; gap: 15px;
        }
        .info-row:last-child { border-bottom: none; }
        
        .info-label { font-weight: 700; color: var(--text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; text-align: left; }
        .info-value { font-weight: 600; color: var(--secondary); font-size: 1rem; text-align: right; word-break: break-all; }

        .role-pill {
            padding: 6px 16px; border-radius: 50px; font-size: 0.75rem; font-weight: 700;
            background: #e6fcf5; color: #0ca678; text-transform: uppercase;
        }

        .action-buttons { margin-top: 40px; display: grid; grid-template-columns: 1fr 1fr; gap: 15px; }
        
        .btn {
            padding: 14px; border-radius: 12px; font-weight: 700; text-decoration: none;
            transition: 0.3s; font-size: 0.9rem; text-align: center; border: none; cursor: pointer;
        }
        .btn-primary { background: var(--primary); color: #fff; box-shadow: 0 8px 20px rgba(255, 107, 107, 0.2); }
        .btn-primary:hover { background: var(--primary-dark); transform: translateY(-3px); }
        
        .btn-outline { background: #f8fafc; color: var(--secondary); border: 1.5px solid #e2e8f0; }
        .btn-outline:hover { background: #edf2f7; }


        /* ----------------------- 5. RESPONSIVE QUERIES ----------------------- */
        @media (max-width: 850px) {
            .nav-links { display: none; }
            .menu-btn { display: block; }
        }
        @media (max-width: 500px) {
            .profile-card { padding: 40px 20px; border-radius: 20px; }
            .action-buttons { grid-template-columns: 1fr; }
            .profile-header h2 { font-size: 1.8rem; }
            .info-row { flex-direction: column; align-items: flex-start; gap: 5px; }
            .info-value { text-align: left; }
        }
    </style>
</head>
<body>

    <header class="navbar">
        <a href="/" class="brand">Bike<span> Rental</span></a>
        <div class="menu-btn" onclick="toggleMenu()"><i class="fas fa-bars"></i></div>
        <nav class="nav-links">
            <a href="/">Home</a>
            <a href="/user/dashboard">Dashboard</a>
            <a href="/user/profile" class="active">My Profile</a>
            <a href="/logout" class="logout-link">Logout</a>
        </nav>
    </header>

    <div class="mobile-overlay" id="mobileNav">
        <div class="close-menu" onclick="toggleMenu()"><i class="fas fa-times"></i></div>
        <a href="/" onclick="toggleMenu()">Home</a>
        <a href="/user/dashboard" onclick="toggleMenu()">Dashboard</a>
        <a href="/user/profile" onclick="toggleMenu()">My Profile</a>
        <a href="/logout" onclick="toggleMenu()">Logout</a>
    </div>

    <main class="container">
        <div class="profile-header">
            <h2>Account Settings</h2>
            <p>View and manage your personal riding profile.</p>
        </div>

        <% if (user) { %>
            <div class="profile-card">
                <div class="avatar-section">
                    <i class="fas fa-user"></i>
                </div>
                
                <div class="info-group">
                    <div class="info-row">
                        <span class="info-label">Full Name</span>
                        <span class="info-value"><%= user.name %></span>
                    </div>
                    
                    <div class="info-row">
                        <span class="info-label">Email Address</span>
                        <span class="info-value"><%= user.email %></span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Phone Number</span>
                        <span class="info-value"><%= user.phone || '+91 9XXXX XXXXX' %></span>
                    </div>

                    <div class="info-row">
                        <span class="info-label">Member Status</span>
                        <span class="role-pill"><%= user.role %></span>
                    </div>
                </div>

                <div class="action-buttons">
                    <a href="/user/dashboard" class="btn btn-primary">My Bookings</a>
                    <a href="/" class="btn btn-outline">Browse Rides</a>
                </div>
            </div>
        <% } else { %>
            <div class="profile-card" style="padding: 60px 40px;">
                <i class="fas fa-user-lock fa-3x" style="color: #cbd5e0; margin-bottom: 20px;"></i>
                <h3>Session Expired</h3>
                <p style="margin: 15px 0 25px; color: var(--text-muted);">Please sign in to access your profile settings.</p>
                <a href="/login" class="btn btn-primary" style="display: block;">Go to Login</a>
            </div>
        <% } %>
    </main>

    <%- include('partials/footer') %>

    <script>
        function toggleMenu() {
            document.getElementById("mobileNav").classList.toggle("active");
        }
    </script>
</body>
</html>