<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Bookings - BikeRental Premium Dashboard</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>

    <style>
        /* ---------------------------------------------------------
           1. CORE DESIGN SYSTEM & REFINED PALETTE
        --------------------------------------------------------- */
        :root {
            --primary: #ff6b6b;
            --primary-dark: #ee5253;
            --secondary: #1e1e2f;
            --secondary-light: #2d2d44;
            --success: #00b894;
            --info: #0984e3;
            --warning: #f1c40f;
            --danger: #d63031;
            --bg-body: #f8fafc;
            --card-bg: #ffffff;
            --text-main: #1a202c;
            --text-muted: #718096;
            --white: #ffffff;
            --shadow-sm: 0 4px 6px rgba(0,0,0,0.05);
            --shadow-md: 0 10px 30px rgba(0,0,0,0.08);
            --shadow-lg: 0 20px 40px rgba(0,0,0,0.12);
            --transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            --radius-xl: 30px;
            --radius-lg: 20px;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        
        body { 
            background: var(--bg-body); 
            color: var(--text-main); 
            overflow-x: hidden; 
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
        }

        /* ---------------------------------------------------------
           2. NAVIGATION BAR
        --------------------------------------------------------- */
        .navbar { 
            background: var(--secondary); 
            padding: 15px 8%; 
            display: flex; 
            justify-content: space-between; 
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 5000;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
        }
        .navbar .brand { 
            font-size: 2rem; 
            font-weight: 800; 
            color: var(--primary); 
            text-decoration: none; 
            letter-spacing: -1px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .navbar .brand span { color: var(--white); font-weight: 300; }
        
        .nav-links { display: flex; gap: 15px; align-items: center; }
        .nav-links a {
            color: var(--white); text-decoration: none; padding: 12px 22px; border-radius: 12px;
            font-weight: 500; font-size: 0.95rem; transition: var(--transition);
        }
        .nav-links a:hover { background: rgba(255, 107, 107, 0.12); color: var(--primary); }
        .active-link { background: rgba(255, 107, 107, 0.18); color: var(--primary) !important; font-weight: 600; }
        
        .logout-pill { 
            color: var(--white) !important; 
            text-decoration: none; 
            font-weight: 700; 
            padding: 12px 25px; 
            border-radius: 15px; 
            background: var(--primary) !important; 
            transition: var(--transition);
            box-shadow: 0 5px 15px rgba(255, 107, 107, 0.3);
            font-size: 0.9rem;
            display: flex;
            align-items: center;
            gap: 8px;
            border: none;
            cursor: pointer;
        }
        .logout-pill:hover { background: var(--primary-dark) !important; transform: translateY(-3px) scale(1.03); }

        .menu-btn { display: none; cursor: pointer; color: var(--white); font-size: 2rem; transition: 0.3s; }

        .mobile-menu-overlay {
            position: fixed; top: 0; right: -100%; width: 100%; height: 100%;
            background: rgba(30, 30, 47, 0.98); z-index: 6000;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            transition: 0.5s cubic-bezier(0.77, 0, 0.175, 1);
            backdrop-filter: blur(10px);
        }
        .mobile-menu-overlay.active { right: 0; }
        .close-menu-btn { position: absolute; top: 30px; right: 40px; color: var(--white); font-size: 3rem; cursor: pointer; }
        .mobile-links { display: flex; flex-direction: column; gap: 35px; text-align: center; }
        .mobile-links a { color: var(--white); text-decoration: none; font-size: 1.8rem; font-weight: 600; transition: 0.3s; }
        .mobile-links a:hover { color: var(--primary); transform: translateY(-5px); }

        /* ---------------------------------------------------------
           3. CUSTOM MODAL SYSTEM (CANCEL, INFO & RATING)
        --------------------------------------------------------- */
        .modal-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(30, 30, 47, 0.85); backdrop-filter: blur(8px);
            z-index: 9999; display: none; align-items: center; justify-content: center;
            padding: 20px;
        }

        .modal-card {
            background: var(--card-bg); padding: 45px; border-radius: var(--radius-lg); 
            width: 100%; max-width: 480px; text-align: center; 
            box-shadow: var(--shadow-md); animation: popIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border-top: 10px solid var(--primary);
        }

        @keyframes popIn { from { transform: scale(0.6); opacity: 0; } to { transform: scale(1); opacity: 1; } }

        .modal-card i.warn-icon { font-size: 5rem; color: var(--primary); margin-bottom: 25px; }
        .modal-card h3 { font-size: 1.8rem; color: var(--secondary); margin-bottom: 15px; font-weight: 800; }
        .modal-card p { color: var(--text-muted); font-size: 1.1rem; margin-bottom: 25px; line-height: 1.7; }

        .modal-btn-group { display: flex; gap: 15px; justify-content: center; }
        .btn-confirm-action { 
            background: var(--primary); color: var(--white); padding: 14px 30px; 
            border-radius: 12px; border: none; font-weight: 700; cursor: pointer; 
            transition: var(--transition); font-size: 1rem; width: 100%;
        }
        .btn-confirm-action:hover { background: var(--primary-dark); transform: translateY(-3px); }

        .btn-cancel-action { 
            background: #f1f2f6; color: #57606f; padding: 14px 30px; 
            border-radius: 12px; border: none; font-weight: 700; cursor: pointer; 
            transition: var(--transition); font-size: 1rem; width: 100%;
        }
        .btn-cancel-action:hover { background: #dfe4ea; }

        /* Star Rating */
        .rating-css { 
            display: flex; flex-direction: row-reverse; justify-content: center; gap: 10px; margin-bottom: 20px; 
        }
        .rating-css input { display: none; }
        .rating-css label { font-size: 2.5rem; color: #cbd5e0; cursor: pointer; transition: 0.2s; }
        .rating-css input:checked ~ label, .rating-css label:hover, .rating-css label:hover ~ label { color: var(--warning); }
        .review-textarea { 
            width: 100%; padding: 15px; border-radius: 12px; border: 2px solid #edf2f7; 
            margin-bottom: 20px; outline: none; font-family: 'Poppins', sans-serif; resize: vertical; 
        }
        .review-textarea:focus { border-color: var(--warning); }

        /* ---------------------------------------------------------
           4. MAIN CONTENT
        --------------------------------------------------------- */
        main.container { width: 92%; max-width: 1300px; margin: 50px auto; flex: 1; animation: fadeIn 0.8s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(40px); } to { opacity: 1; transform: translateY(0); } }

        .summary-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 25px; margin-bottom: 50px; }
        .stat-card {
            background: var(--card-bg); padding: 35px; border-radius: 28px;
            box-shadow: var(--shadow-md); border-left: 8px solid var(--primary);
            transition: var(--transition); position: relative; overflow: hidden; border: 1px solid #edf2f7;
        }
        .stat-card:hover { transform: translateY(-10px); box-shadow: 0 20px 40px rgba(0,0,0,0.12); border-color: var(--primary); }
        .stat-card p { font-size: 0.9rem; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1.2px; }
        .stat-card h3 { font-size: 2.5rem; color: var(--secondary); margin-top: 10px; font-weight: 800; }
        .stat-card i { position: absolute; right: 25px; bottom: 25px; font-size: 3.5rem; color: rgba(0,0,0,0.03); }

        .dashboard-header { margin-bottom: 40px; border-bottom: 3px solid #f0f0f0; padding-bottom: 20px; }
        .dashboard-header h2 { font-size: 2.5rem; font-weight: 800; color: var(--secondary); }

        /* ---------------------------------------------------------
           5. DATA TABLE
        --------------------------------------------------------- */
        .data-card { background: var(--card-bg); border-radius: 28px; overflow: hidden; box-shadow: var(--shadow-md); border: 1px solid #edf2f7; }
        table { width: 100%; border-collapse: collapse; }
        table th { background: #f8fafc; padding: 25px; text-align: left; font-size: 0.85rem; text-transform: uppercase; letter-spacing: 1.5px; color: var(--text-muted); border-bottom: 2px solid #edf2f7; }
        table td { padding: 25px; border-bottom: 1px solid #f1f5f9; font-size: 1rem; vertical-align: middle; }
        table tr:last-child td { border-bottom: none; }
        table tr:hover { background-color: #fafbff; }

        .action-cell { display: flex; flex-direction: column; gap: 10px; max-width: 180px; margin: 0 auto; }
        
        .pdf-btn {
            background: none; border: 2.5px solid var(--primary); color: var(--primary);
            padding: 10px 18px; border-radius: 12px; cursor: pointer; font-weight: 700; font-size: 0.9rem; transition: var(--transition); display: flex; align-items: center; gap: 10px; width: 100%; justify-content: center;
        }
        .pdf-btn:hover { background: var(--primary); color: var(--white); box-shadow: 0 6px 15px rgba(255, 107, 107, 0.25); }
        .pdf-btn.locked { border-color: #cbd5e0; color: #94a3b8; cursor: not-allowed; opacity: 0.75; }

        .cancel-btn-trigger { background: #fff5f5; border: 1.5px solid #ff7675; color: var(--danger); padding: 10px 18px; border-radius: 12px; cursor: pointer; font-weight: 600; font-size: 0.9rem; transition: var(--transition); text-align: center; display: block; }
        .cancel-btn-trigger:hover { background: var(--danger); color: var(--white); transform: scale(1.03); }

        .status { padding: 8px 20px; border-radius: 35px; font-size: 0.8rem; font-weight: 700; display: inline-block; text-transform: uppercase; letter-spacing: 0.8px; }
        .status-pending { background: #fff9db; color: #f08c00; border: 1.5px solid #ffe066; }
        .status-approved { background: #e3f2fd; color: #1976d2; border: 1.5px solid #90caf9; }
        .status-ongoing { background: #e6fcf5; color: #0ca678; border: 1.5px solid #63e6be; }
        .status-completed { background: #f1f3f5; color: #495057; border: 1.5px solid #dee2e6; }
        .status-cancelled { background: #fdf2f2; color: var(--danger); border: 1.5px solid #feb2b2; }

        /* ---------------------------------------------------------
           6. PAGINATION (FIXED FOR MOBILE & DESKTOP)
        --------------------------------------------------------- */
        .pagination { 
            display: flex; justify-content: center; align-items: center; gap: 10px; 
            margin-top: 40px; margin-bottom: 20px; flex-wrap: wrap; /* Allows wrapping on mobile */
        }
        .page-btn { 
            padding: 10px 20px; background: var(--card-bg); border: 1.5px solid #edf2f7; 
            text-decoration: none; border-radius: 12px; color: var(--secondary); 
            font-weight: 600; transition: var(--transition); box-shadow: var(--shadow-sm); 
        }
        .page-btn:hover:not(.disabled) { 
            background: var(--primary); color: #fff; border-color: var(--primary); transform: translateY(-2px); 
        }
        .page-btn.active { 
            background: var(--secondary); color: #fff; border-color: var(--secondary); font-weight: 700;
        }
        .page-btn.disabled { 
            opacity: 0.5; cursor: not-allowed; pointer-events: none; background: #f8fafc;
        }

        /* ---------------------------------------------------------
           7. FOOTER
        --------------------------------------------------------- */
        footer { background: var(--secondary); color: var(--white); padding: 90px 8% 50px; margin-top: auto; border-top: 10px solid var(--primary); }
        .footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 60px; }
        .footer-brand h3 { color: var(--primary); font-size: 2.2rem; font-weight: 800; margin-bottom: 25px; }
        .footer-brand p { color: #cbd5e0; line-height: 1.9; font-size: 0.95rem; }
        .footer-links h4 { font-size: 1.3rem; margin-bottom: 30px; position: relative; padding-bottom: 12px; font-weight: 700; }
        .footer-links h4::after { content: ''; position: absolute; left: 0; bottom: 0; width: 45px; height: 4px; background: var(--primary); border-radius: 2px; }
        .footer-links ul { list-style: none; }
        .footer-links li { margin-bottom: 18px; }
        .footer-links a { color: #cbd5e0; text-decoration: none; transition: 0.3s; font-size: 1rem; display: flex; align-items: center; gap: 10px; }
        .footer-links a:hover { color: var(--primary); padding-left: 10px; }
        .copyright { text-align: center; padding-top: 50px; margin-top: 80px; border-top: 1px solid rgba(255,255,255,0.08); color: #718096; font-size: 0.95rem; }

        /* ---------------------------------------------------------
           8. RESPONSIVE BREAKPOINTS
        --------------------------------------------------------- */
        @media (max-width: 1024px) { 
            .navbar { padding: 15px 5%; } .nav-links { display: none; } .menu-btn { display: block; } 
        }
        @media (max-width: 768px) {
            .summary-grid { grid-template-columns: 1fr; gap: 15px; }
            .data-card { border: none; background: transparent; box-shadow: none; }
            table, thead, tbody, th, td, tr { display: block; width: 100%; }
            table thead { display: none; }
            table tr { background: var(--white); padding: 30px; border-radius: 25px; margin-bottom: 25px; box-shadow: var(--shadow-md); border: 1px solid #eee; position: relative; }
            table td { display: flex; justify-content: space-between; align-items: center; padding: 15px 0; border: none; text-align: right; border-bottom: 1.5px dashed #f0f0f0; }
            table td:last-child { border-bottom: none; flex-direction: column; padding-top: 20px; }
            table td::before { content: attr(data-label); font-weight: 800; color: var(--secondary); text-align: left; text-transform: uppercase; font-size: 0.8rem; }
            .action-cell { max-width: 100%; width: 100%; margin-top: 10px; }
            .pagination { gap: 8px; }
            .page-btn { padding: 10px 15px; font-size: 0.9rem; }
        }
    </style>
</head>
<body>

    <div class="mobile-menu-overlay" id="mobileMenu">
        <div class="close-menu-btn" onclick="toggleMobileNav()"><i class="fas fa-times"></i></div>
        <div class="mobile-links">
            <a href="/" onclick="toggleMobileNav()">Browse Fleet</a>
            <a href="/user/dashboard" class="active-link" onclick="toggleMobileNav()">My Bookings</a>
            <a href="/user/profile" onclick="toggleMobileNav()">My Profile</a>
            <a href="/logout" class="logout-pill" style="padding: 15px 40px; display: inline-block;">Logout</a>
        </div>
    </div>

    <div class="modal-overlay" id="infoModal">
        <div class="modal-card">
            <i class="fas fa-file-shield warn-icon"></i>
            <h3>Digital Receipt Locked</h3>
            <p>Your official tax invoice will be generated and available for download once the trip is marked as <strong>'Completed'</strong> by the administration.</p>
            <button class="btn-confirm-action" onclick="closeModal('infoModal')">Understood</button>
        </div>
    </div>

    <div class="modal-overlay" id="rateInfoModal">
        <div class="modal-card" style="border-top-color: var(--info);">
            <i class="fas fa-star-half-stroke warn-icon" style="color: var(--info);"></i>
            <h3>Rating Unavailable</h3>
            <p>Bhai, aap ride complete hone ke baad hi apna feedback aur rating submit kar sakte hain. Have a safe trip!</p>
            <button class="btn-confirm-action" style="background: var(--info);" onclick="closeModal('rateInfoModal')">Okay, Understood</button>
        </div>
    </div>

    <div class="modal-overlay" id="cancelConfirmModal">
        <div class="modal-card">
            <i class="fas fa-ban warn-icon" style="color: #fab1a0;"></i>
            <h3>Cancel This Ride?</h3>
            <p>Are you sure you want to cancel the booking for <strong id="bikeNamePop" style="color: var(--secondary);"></strong>? This action cannot be undone.</p>
            <div class="modal-btn-group">
                <button type="button" class="btn-cancel-action" onclick="closeModal('cancelConfirmModal')" style="flex:1;">No, Keep it</button>
                <form id="finalCancelForm" method="POST" style="flex: 1;">
                    <button type="submit" class="btn-confirm-action">Yes, Cancel Ride</button>
                </form>
            </div>
        </div>
    </div>

    <div class="modal-overlay" id="reviewModal">
        <div class="modal-card" style="border-top-color: var(--warning);">
            <i class="fas fa-star warn-icon" style="color: var(--warning);"></i>
            <h3>Rate Your Experience</h3>
            <p>How was your ride with <strong id="reviewBikeName" style="color: var(--secondary);"></strong>?</p>
            
            <form id="reviewForm" method="POST">
                <div class="rating-css">
                    <input type="radio" name="rating" id="star5" value="5" required><label for="star5" class="fas fa-star"></label>
                    <input type="radio" name="rating" id="star4" value="4"><label for="star4" class="fas fa-star"></label>
                    <input type="radio" name="rating" id="star3" value="3"><label for="star3" class="fas fa-star"></label>
                    <input type="radio" name="rating" id="star2" value="2"><label for="star2" class="fas fa-star"></label>
                    <input type="radio" name="rating" id="star1" value="1"><label for="star1" class="fas fa-star"></label>
                </div>
                
                <textarea name="comment" class="review-textarea" rows="3" placeholder="Tell us about your trip..." required></textarea>
                <input type="hidden" name="bikeId" id="reviewBikeId">
                
                <div class="modal-btn-group">
                    <button type="button" class="btn-cancel-action" onclick="closeModal('reviewModal')" style="flex:1;">Cancel</button>
                    <button type="submit" class="btn-confirm-action" style="flex:1; background: var(--warning);">Submit Review</button>
                </div>
            </form>
        </div>
    </div>

    <header class="navbar">
        <a href="/" class="brand">Bike<span>Rental</span></a>
        <nav class="nav-links">
            <a href="/">Browse Bikes</a>
            <a href="/user/dashboard" class="active-link">My Bookings</a>
            <a href="/user/profile">Profile</a>
            <a href="/logout" class="logout-pill">Logout</a>
        </nav>
        <div class="menu-btn" onclick="toggleMobileNav()"><i class="fas fa-bars"></i></div>
    </header>

    <main class="container">
        <div class="summary-grid">
            <div class="stat-card">
                <i class="fas fa-clipboard-list bg-icon"></i>
                <p class="label">Total Bookings</p>
                <h3 class="value"><%= requests.length %></h3>
            </div>
            <div class="stat-card" style="border-left-color: var(--success);">
                <i class="fas fa-bolt bg-icon"></i>
                <p class="label">Live Rides</p>
                <h3 class="value"><%= requests.filter(r => r.status === 'ongoing' || r.status === 'approved').length %></h3>
            </div>
            <div class="stat-card" style="border-left-color: var(--warning);">
                <i class="fas fa-indian-rupee-sign bg-icon"></i>
                <p class="label">Total Spending</p>
                <h3 class="value">₹ <%= requests.reduce((acc, curr) => acc + curr.totalPrice, 0).toLocaleString('en-IN') %></h3>
            </div>
        </div>

        <div class="dashboard-header">
            <div>
                <h2>Your Ride History</h2>
                <p>Manage your rentals, download invoices, and rate your trips.</p>
            </div>
        </div>

        <% if (!requests || requests.length === 0) { %>
            <div style="text-align: center; padding: 120px 20px; background: #fff; border-radius: 35px; box-shadow: var(--shadow-sm); border: 3px dashed #cbd5e0;">
                <i class="fas fa-motorcycle fa-5x" style="color: #cbd5e0; margin-bottom: 25px;"></i>
                <h3 style="color: var(--secondary); font-size: 2rem;">No Rides Booked Yet</h3>
                <p style="color: var(--text-muted); margin-bottom: 35px; font-size: 1.1rem;">Ready for an adventure? Start by choosing your dream bike today!</p>
                <a href="/" style="background: var(--primary); color:#fff; padding: 18px 45px; border-radius: 18px; text-decoration: none; font-weight: 700; font-size: 1.2rem; box-shadow: 0 10px 25px rgba(255, 107, 107, 0.35);">Explore Bikes</a>
            </div>
        <% } else { %>
            <div class="data-card">
                <table>
                    <thead>
                        <tr>
                            <th>Vehicle Details</th>
                            <th>Schedule (Pickup - Return)</th>
                            <th>Total Amount</th>
                            <th>Current Status</th>
                            <th style="text-align: center;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% requests.forEach(r => { %>
                            <tr>
                                <td data-label="Vehicle" style="font-weight: 700; color: var(--secondary); font-size: 1.1rem;">
                                    <div style="display:flex; align-items:center; gap: 10px;">
                                        <i class="fas fa-circle-check" style="color: var(--success); font-size: 0.9rem;"></i>
                                        <%= r.bike ? r.bike.name : 'Premium Bike' %>
                                    </div>
                                </td>
                                <td data-label="Schedule" style="font-size: 0.9rem; line-height: 1.8;">
                                    <div style="color: var(--success); font-weight: 700;"><i class="far fa-calendar-plus"></i> Pickup: <%= new Date(r.pickupDateTime).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short' }) %></div>
                                    <div style="color: var(--text-muted);"><i class="far fa-calendar-minus"></i> Return: <%= new Date(r.returnDateTime).toLocaleString('en-IN', { dateStyle: 'medium', timeStyle: 'short' }) %></div>
                                </td>
                                <td data-label="Amount" style="font-weight: 800; color: var(--secondary); font-size: 1.2rem;">₹ <%= r.totalPrice.toLocaleString('en-IN') %></td>
                                <td data-label="Status"><span class="status status-<%= r.status %>"><%= r.status %></span></td>
                                <td data-label="Actions">
                                    <div class="action-cell">
                                        <button class="pdf-btn <%= r.status !== 'completed' ? 'locked' : '' %>" 
                                            onclick="handleReceiptAction('<%= r.status %>', '<%= r.bike ? r.bike.name : 'Bike' %>', '<%= r.totalPrice %>', '<%= new Date(r.pickupDateTime).toLocaleDateString('en-IN') %>')">
                                            <i class="<%= r.status !== 'completed' ? 'fas fa-lock' : 'fas fa-file-invoice-dollar' %>"></i> 
                                            <%= r.status === 'completed' ? 'Download Receipt' : 'Locked' %>
                                        </button>

                                        <% if (r.status === 'pending' || r.status === 'approved') { %>
                                            <div class="cancel-btn-trigger" onclick="openCancelConfirmation('<%= r._id %>', '<%= r.bike ? r.bike.name : 'Motorcycle' %>')">
                                                <i class="fas fa-ban"></i> Cancel Booking
                                            </div>
                                        <% } %>

                                        <% if (!r.isReviewed) { %>
                                            <button class="pdf-btn <%= r.status !== 'completed' ? 'locked' : '' %>" style="<%= r.status === 'completed' ? 'background: var(--warning); color: #fff; border-color: var(--warning);' : '' %>"
                                                onclick="handleRateAction('<%= r.status %>', '<%= r._id %>', '<%= r.bike ? r.bike._id : '' %>', '<%= r.bike ? r.bike.name : 'Bike' %>')">
                                                <i class="<%= r.status !== 'completed' ? 'fas fa-lock' : 'fas fa-star' %>"></i> Rate Ride
                                            </button>
                                        <% } else { %>
                                            <div style="text-align: center; font-size: 0.85rem; color: var(--success); font-weight: 800; background: rgba(0, 184, 148, 0.1); padding: 8px; border-radius: 12px; display: flex; align-items: center; justify-content: center; gap: 5px;">
                                                <i class="fas fa-check-double"></i> Reviewed
                                            </div>
                                        <% } %>
                                    </div>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>

            <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
                <% const curr = Number(currentPage) || 1; %>
                <div class="pagination">
                    <a href="/user/dashboard?page=<%= curr > 1 ? curr - 1 : 1 %>" class="page-btn <%= curr === 1 ? 'disabled' : '' %>"><i class="fas fa-chevron-left"></i> Previous</a>
                    <% for(let i = 1; i <= totalPages; i++) { %>
                        <a href="/user/dashboard?page=<%= i %>" class="page-btn <%= curr === i ? 'active' : '' %>"><%= i %></a>
                    <% } %>
                    <a href="/user/dashboard?page=<%= curr < totalPages ? curr + 1 : totalPages %>" class="page-btn <%= curr === totalPages ? 'disabled' : '' %>">Next <i class="fas fa-chevron-right"></i></a>
                </div>
            <% } %>

        <% } %>
    </main>

    <footer>
        <div class="footer-grid">
            <div class="footer-brand">
                <h3>BikeRental</h3>
                <p>Premium mobility solutions for the modern explorer. Experience the freedom of the open road with our top-of-the-line fleet.</p>
            </div>
            <div class="footer-links">
                <h4>Quick Links</h4>
                <ul>
                    <li><a href="/">Browse Bikes</a></li>
                    <li><a href="/user/profile">My Profile</a></li>
                    <li><a href="/terms">Terms & Conditions</a></li>
                </ul>
            </div>
            <div class="footer-links">
                <h4>Contact Support</h4>
                <p style="color:#b2bec3; font-size:0.95rem; margin-bottom:15px;"><i class="fas fa-envelope" style="color:var(--primary); margin-right:12px;"></i> support@bikerental.com</p>
                <p style="color:#b2bec3; font-size:0.95rem;"><i class="fas fa-phone" style="color:var(--primary); margin-right:12px;"></i> +91 98765 43210</p>
            </div>
        </div>
        <div class="copyright">
            <p>© <%= new Date().getFullYear() %> BikeRental System | Developed by Aniket Kumar Gupta</p>
        </div>
    </footer>

    <script>
        function toggleScrollLock(lock) { document.body.style.overflow = lock ? 'hidden' : 'auto'; }

        function toggleMobileNav() { 
            const menu = document.getElementById('mobileMenu');
            menu.classList.toggle('active');
            toggleScrollLock(menu.classList.contains('active'));
        }

        function openModal(id) { 
            const modal = document.getElementById(id);
            modal.style.display = "flex"; 
            toggleScrollLock(true);
        }

        function closeModal(id) { 
            const modal = document.getElementById(id);
            modal.style.display = "none"; 
            toggleScrollLock(false);
        }

        function openCancelConfirmation(bookingId, bikeName) {
            document.getElementById('bikeNamePop').innerText = bikeName;
            document.getElementById('finalCancelForm').action = `/user/cancel-booking/${bookingId}`;
            openModal('cancelConfirmModal');
        }

        // Rating Handling
        function handleRateAction(status, bookingId, bikeId, bikeName) {
            if (status !== 'completed') {
                openModal('rateInfoModal');
                return;
            }
            document.getElementById('reviewBikeName').innerText = bikeName;
            document.getElementById('reviewBikeId').value = bikeId;
            document.getElementById('reviewForm').action = `/review/${bookingId}`;
            openModal('reviewModal');
        }

        // Receipt Handling
        function handleReceiptAction(status, bike, price, date) {
            if (status !== 'completed') { openModal('infoModal'); return; }
            
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            
            doc.setFillColor(30, 30, 47); doc.rect(0, 0, 210, 45, 'F');
            doc.setTextColor(255, 255, 255); doc.setFontSize(26); doc.setFont("helvetica", "bold");
            doc.text("BikeRental", 15, 25);
            doc.setFontSize(10); doc.setFont("helvetica", "normal"); doc.text("OFFICIAL RIDE INVOICE", 15, 33);
            doc.setFontSize(20); doc.text("INVOICE", 160, 28);
            
            doc.setTextColor(40, 40, 40); doc.setFontSize(11); doc.setFont("helvetica", "bold");
            doc.text("BILLED TO: Registered Rider", 15, 60);
            
            const invID = "INV-" + Math.floor(Math.random() * 900000 + 100000);
            doc.text("INVOICE NO:", 140, 60); doc.setFont("helvetica", "normal"); doc.text(invID, 170, 60);
            doc.setFont("helvetica", "bold"); doc.text("DATE:", 140, 66); doc.setFont("helvetica", "normal"); doc.text(date, 170, 66);

            doc.setFillColor(245, 247, 254); doc.rect(15, 85, 180, 10, 'F');
            doc.setFont("helvetica", "bold"); doc.text("DESCRIPTION", 20, 92); doc.text("AMOUNT", 165, 92);
            
            doc.setFont("helvetica", "normal"); doc.text(`Motorcycle Rental - ${bike}`, 20, 105); doc.text(`Rs. ${price}.00`, 165, 105);
            doc.line(15, 115, 195, 115);
            
            doc.setFontSize(14); doc.setFont("helvetica", "bold"); doc.text("GRAND TOTAL", 110, 135);
            doc.setTextColor(255, 107, 107); doc.text(`INR ${price}.00`, 160, 135);

            doc.setDrawColor(255, 107, 107); doc.setLineWidth(0.5); doc.roundedRect(160, 145, 30, 12, 2, 2, 'S');
            doc.setFontSize(12); doc.text("PAID", 170, 153);

            doc.setTextColor(150, 150, 150); doc.setFontSize(8); doc.setFont("helvetica", "italic");
            doc.text("Computer generated document. Ride safe!", 105, 280, {align: "center"});

            doc.save(`${invID}_Receipt.pdf`);
        }
    </script>
</body>
</html>